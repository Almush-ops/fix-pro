---
const navItems = [
  { label: 'שירותים', href: '/services/' },
  { label: 'מחירון', href: '/pricing/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'אודות', href: '/about/' },
  { label: 'צור קשר', href: '/contact/' },
];

const phone = '055-432-9235';
const phoneHref = 'tel:+972554329235';
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo (right side in RTL) -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-xl lg:text-2xl font-heading font-bold text-brand-700 group-hover:text-brand-800 transition-colors">
          פיקס פרו
        </span>
      </a>

      <!-- Desktop: Nav + CTA together (left side in RTL) -->
      <div class="hidden lg:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-brand-600',
              isActive(item.href) ? 'text-brand-600' : 'text-dark/70',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={phoneHref}
          class="flex items-center gap-2 bg-accent-500 text-white px-5 py-2.5 rounded-md text-sm font-semibold hover:bg-accent-600 transition-colors shadow-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          <span>{phone}</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-dark/70 hover:text-dark"
        aria-label="פתח תפריט"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-border mt-2 pt-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3 text-base font-medium transition-colors hover:text-brand-600 border-b border-border/50',
            isActive(item.href) ? 'text-brand-600' : 'text-dark/70',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={phoneHref}
        class="flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-accent-600 transition-colors mt-4"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <span>חייגו עכשיו: {phone}</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
