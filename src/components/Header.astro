---
const navItems = [
  { label: 'שירותים', href: '/services/' },
  { label: 'מחירון', href: '/pricing/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'אודות', href: '/about/' },
  { label: 'צור קשר', href: '/contact/' },
];

const phone = '055-432-9235';
const phoneHref = 'tel:+972554329235';
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- Main Header (Dark Navy - Plumber Style) -->
<header class="sticky top-0 z-50 bg-brand-600 shadow-lg">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo (right side in RTL) -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center border border-white/20">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <span class="text-xl lg:text-2xl font-heading font-bold text-white group-hover:text-accent-400 transition-colors">
          פיקס פרו
        </span>
      </a>

      <!-- Desktop: Nav + CTA together (left side in RTL) -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-accent-400',
              isActive(item.href) ? 'text-accent-400' : 'text-white/80',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={phoneHref}
          class="flex items-center gap-2 bg-accent-500 text-white px-5 py-2.5 rounded-lg text-sm font-bold hover:bg-accent-600 transition-colors shadow-lg shadow-accent-500/30"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          <span>התקשרו עכשיו</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-white/80 hover:text-white"
        aria-label="פתח תפריט"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-white/10 mt-2 pt-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3 text-base font-medium transition-colors hover:text-accent-400 border-b border-white/10',
            isActive(item.href) ? 'text-accent-400' : 'text-white/80',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={phoneHref}
        class="flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 rounded-lg text-base font-bold hover:bg-accent-600 transition-colors mt-4"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <span>חייגו עכשיו: {phone}</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
