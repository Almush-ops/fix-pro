---
/**
 * WhatsApp Button - SINGLE SOURCE OF TRUTH
 *
 * All WhatsApp buttons across the site MUST use this component.
 * This ensures:
 * 1. Consistent popup behavior (collects phone before opening WhatsApp)
 * 2. Lead capture via webhook
 * 3. Correct partner phone number
 *
 * DO NOT create inline wa.me links anywhere else!
 */

interface Props {
  variant?: 'primary' | 'outline' | 'icon-only';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  text?: string;
}

const {
  variant = 'primary',
  size = 'md',
  class: className = '',
  text = 'WhatsApp',
} = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm gap-1.5',
  md: 'px-6 py-3 text-base gap-2',
  lg: 'px-8 py-4 text-lg gap-2',
};

const variantClasses = {
  primary: 'bg-green-500 text-white hover:bg-green-600',
  outline: 'border-2 border-green-500 text-green-600 hover:bg-green-50',
  'icon-only': 'bg-green-500 text-white hover:bg-green-600 !p-3',
};

const baseClasses = 'whatsapp-popup-trigger inline-flex items-center justify-center font-bold transition-colors cursor-pointer';
---

<button
  type="button"
  class:list={[baseClasses, sizeClasses[size], variantClasses[variant], className]}
>
  <svg class={size === 'sm' ? 'w-4 h-4' : 'w-5 h-5'} fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
  {variant !== 'icon-only' && <span>{text}</span>}
</button>

<script>
  // All WhatsApp buttons with this class trigger the popup in BaseLayout
  document.querySelectorAll('.whatsapp-popup-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-whatsapp-popup'));
    });
  });
</script>
