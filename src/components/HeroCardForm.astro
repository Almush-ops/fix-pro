---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'טכנאי מזגנים, אינסטלטור והנדימן בחיפה והקריות',
  subtitle = 'שירות מהיר ומקצועי לכל בעיה בבית - הגעה תוך שעתיים, מחיר שקוף מראש.',
} = Astro.props;

const phone = '055-432-9235';
---

<section class="relative min-h-[600px] lg:min-h-[700px] overflow-hidden">
  <!-- Background Image with Dark Overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/hero-hvac-pro.webp"
      alt="בעל מקצוע מנוסה בעבודה"
      class="w-full h-full object-cover object-center"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Dark gradient overlay - stronger on the right (text side in RTL) -->
    <div class="absolute inset-0 bg-gradient-to-l from-brand-700/95 via-brand-700/85 to-brand-700/60"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[450px]">
      <!-- Content (right side in RTL) -->
      <div class="text-center lg:text-start order-2 lg:order-1">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-white leading-tight mb-6">
          טכנאי מזגנים, אינסטלטור והנדימן<br/>
          <span class="text-accent-500">בחיפה והקריות</span>
        </h1>

        <p class="text-lg md:text-xl text-white/80 max-w-xl mx-auto lg:mx-0 mb-8">
          מגיעים תוך שעתיים, מחיר שקוף מראש, אחריות על כל עבודה. ניקוי מיני מרכזי ב-450₪ בלבד.
        </p>

        <!-- CTA Buttons - White outlined + Orange solid -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-8 py-4 text-lg font-bold hover:bg-accent-600 transition-colors shadow-xl"
          >
            קבלו הצעת מחיר
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <a
            href="tel:+972554329235"
            class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 text-lg font-bold hover:bg-white hover:text-dark transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            {phone}
          </a>
        </div>
      </div>

      <!-- Form Card (left side in RTL) -->
      <div class="order-1 lg:order-2">
        <div class="bg-white shadow-2xl p-6 md:p-8 max-w-md mx-auto lg:mx-0 lg:ms-auto">
          <h2 class="text-xl font-heading font-bold text-dark mb-2 text-center">
            השאירו פרטים ונחזור אליכם
          </h2>
          <p class="text-muted text-sm text-center mb-6">
            בדרך כלל חוזרים תוך 10 דקות
          </p>

          <form id="hero-lead-form" class="space-y-4">
            <div>
              <label for="hero-name" class="block text-sm font-medium text-dark mb-1.5">שם מלא</label>
              <input
                type="text"
                id="hero-name"
                name="name"
                required
                class="w-full px-4 py-3 border border-border text-dark placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                placeholder="הכניסו את שמכם"
              />
            </div>
            <div>
              <label for="hero-phone" class="block text-sm font-medium text-dark mb-1.5">טלפון</label>
              <input
                type="tel"
                id="hero-phone"
                name="phone"
                required
                dir="ltr"
                class="w-full px-4 py-3 border border-border text-dark text-right placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                placeholder="050-0000000"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-accent-500 text-white py-3.5 px-6 font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg shadow-accent-500/25"
            >
              התקשרו אליי
            </button>
          </form>

          <div class="mt-4 text-center">
            <span class="text-muted text-sm">או</span>
          </div>

          <!-- WhatsApp button - triggers popup in BaseLayout -->
          <button
            type="button"
            id="hero-whatsapp-btn"
            class="w-full mt-4 flex items-center justify-center gap-2 bg-green-500 text-white py-3 px-6 font-bold hover:bg-green-600 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            שלחו הודעת WhatsApp
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Form submission
  const form = document.getElementById('hero-lead-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const h1 = document.querySelector('h1')?.textContent?.trim() || document.title;

    const data = {
      'your-name': formData.get('name'),
      'phone': formData.get('phone'),
      'page-title': h1,
      'website': 'פיקס פרו',
      'category': 'בעלי מקצוע',
    };

    try {
      await fetch('https://hook.eu1.make.com/vafte51w7nn4tmtyejfl46cooalp0aru', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      // Show success message
      form.innerHTML = `
        <div class="text-center py-8">
          <div class="w-16 h-16 bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">תודה רבה!</h3>
          <p class="text-muted">קיבלנו את הפרטים שלכם ונחזור אליכם בהקדם.</p>
        </div>
      `;
    } catch (error) {
      console.error('Form submission error:', error);
    }
  });

  // WhatsApp button opens popup
  const whatsappBtn = document.getElementById('hero-whatsapp-btn');
  whatsappBtn?.addEventListener('click', () => {
    // Trigger the WhatsApp popup in BaseLayout
    document.dispatchEvent(new CustomEvent('open-whatsapp-popup'));
  });
</script>
