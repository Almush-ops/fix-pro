---
interface Service {
  title: string;
  description: string;
  image: string;
  href: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  services?: Service[];
}

const {
  title = 'השירותים שלנו',
  subtitle = 'כל מה שצריך לבית - במקום אחד',
  services = [
    {
      title: 'מיזוג אוויר',
      description: 'ניקוי, תיקון, התקנה והחלפת מזגנים. שירות מקצועי לכל סוגי המזגנים - עילי, מיני מרכזי ומרכזי.',
      image: '/images/gallery/gal-hvac-work-1.webp',
      href: '/services/air-conditioning/',
    },
    {
      title: 'אינסטלציה',
      description: 'טיפול בנזילות, סתימות, תיקון צנרת והתקנת אביזרי אמבטיה ומטבח. פתרון מהיר ומקצועי.',
      image: '/images/gallery/gal-ac-unit-close.webp',
      href: '/services/plumbing/',
    },
    {
      title: 'הנדימן',
      description: 'עבודות קטנות, תחזוקה, תיקונים ושיפוצים קלים לבית ולעסק. כל מה שצריך במקום אחד.',
      image: '/images/gallery/gal-hvac-work-2.webp',
      href: '/services/handyman/',
    },
  ],
} = Astro.props;
---

<!-- Services Section - Plumber Style with Image Cards -->
<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Service Cards Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group bg-brand-600 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
          <!-- Image -->
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width="400"
              height="300"
              loading="lazy"
            />
          </div>

          <!-- Content -->
          <div class="p-6">
            <h3 class="text-xl font-heading font-bold text-white mb-3">
              {service.title}
            </h3>
            <p class="text-white/70 leading-relaxed mb-5 text-sm">
              {service.description}
            </p>

            <!-- CTA Button - Coral -->
            <a
              href={service.href}
              class="inline-flex items-center gap-2 bg-accent-500 text-white px-6 py-2.5 rounded-lg font-bold text-sm hover:bg-accent-600 transition-colors"
            >
              למידע נוסף
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
