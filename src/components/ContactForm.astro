---
interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'default' | 'card';
}

const {
  title = 'השאירו פרטים ונחזור אליכם',
  subtitle = 'מלאו את הפרטים ונציג יחזור אליכם בהקדם',
  variant = 'default',
} = Astro.props;

const phone = '055-432-9235';
---

<section id="contact" class={`py-16 md:py-20 ${variant === 'card' ? 'bg-surface' : 'bg-white'}`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-xl mx-auto">
      {variant === 'card' ? (
        <div class="bg-white shadow-lg p-6 md:p-8 border border-border">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark text-center mb-2">
            {title}
          </h2>
          <p class="text-muted text-center mb-6">{subtitle}</p>

          <form id="contact-form" class="space-y-4">
            <div>
              <label for="contact-name" class="block text-sm font-medium text-dark mb-1.5">שם מלא</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="w-full px-4 py-3 border border-border text-dark placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                placeholder="הכניסו את שמכם"
              />
            </div>
            <div>
              <label for="contact-phone" class="block text-sm font-medium text-dark mb-1.5">טלפון</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                required
                dir="ltr"
                class="w-full px-4 py-3 border border-border text-dark text-right placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                placeholder="050-0000000"
              />
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-dark mb-1.5">הודעה (אופציונלי)</label>
              <textarea
                id="contact-message"
                name="message"
                rows="3"
                class="w-full px-4 py-3 border border-border text-dark placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow resize-none"
                placeholder="ספרו לנו במה נוכל לעזור..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-accent-500 text-white py-3.5 px-6 font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg shadow-accent-500/25"
            >
              שליחה
            </button>
          </form>

          <p class="text-center text-muted text-sm mt-4">
            או התקשרו ישירות: <a href="tel:0554329235" class="text-accent-500 font-semibold hover:underline">{phone}</a>
          </p>
        </div>
      ) : (
        <>
          <div class="text-center mb-8">
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-2">{title}</h2>
            <p class="text-muted">{subtitle}</p>
          </div>

          <form id="contact-form" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="contact-name" class="block text-sm font-medium text-dark mb-1.5">שם מלא</label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  class="w-full px-4 py-3 border border-border text-dark placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                  placeholder="הכניסו את שמכם"
                />
              </div>
              <div>
                <label for="contact-phone" class="block text-sm font-medium text-dark mb-1.5">טלפון</label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  required
                  dir="ltr"
                  class="w-full px-4 py-3 border border-border text-dark text-right placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow"
                  placeholder="050-0000000"
                />
              </div>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-dark mb-1.5">הודעה (אופציונלי)</label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 border border-border text-dark placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-shadow resize-none"
                placeholder="ספרו לנו במה נוכל לעזור..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-accent-500 text-white py-3.5 px-6 font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg shadow-accent-500/25"
            >
              שליחה
            </button>
          </form>

          <p class="text-center text-muted text-sm mt-6">
            או התקשרו ישירות: <a href="tel:0554329235" class="text-accent-500 font-semibold hover:underline">{phone}</a>
          </p>
        </>
      )}
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const h1 = document.querySelector('h1')?.textContent?.trim() || document.title;

    const data = {
      'your-name': formData.get('name'),
      'phone': formData.get('phone'),
      'message': formData.get('message') || '',
      'page-title': h1,
      'website': 'פיקס פרו',
      'category': 'בעלי מקצוע',
    };

    try {
      await fetch('https://hook.eu1.make.com/vafte51w7nn4tmtyejfl46cooalp0aru', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      // Show success
      form.innerHTML = `
        <div class="text-center py-8">
          <div class="w-16 h-16 bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">תודה רבה!</h3>
          <p class="text-muted">קיבלנו את הפרטים שלכם ונחזור אליכם בהקדם.</p>
        </div>
      `;
    } catch (error) {
      console.error('Form submission error:', error);
    }
  });
</script>
