---
const currentYear = new Date().getFullYear();
const phone = '055-432-9235';
const phoneHref = 'tel:0554329235';
const email = 'info@fix-pro.co.il';
const address = 'חיפה והקריות';

const whatsappNumber = '972554329235';
const whatsappMessage = encodeURIComponent('היי, אשמח לקבל הצעת מחיר');

const services = [
  { label: 'מיזוג אוויר', href: '/services/air-conditioning/', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
  { label: 'ניקוי מזגנים', href: '/air-conditioning/cleaning/', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { label: 'תיקון מזגנים', href: '/air-conditioning/repair/', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { label: 'התקנת מזגנים', href: '/air-conditioning/installation/', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
  { label: 'אינסטלציה', href: '/services/plumbing/', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { label: 'הנדימן', href: '/services/handyman/', icon: 'M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z' },
];

const areas = [
  { label: 'חיפה', href: '/areas/haifa/' },
  { label: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
  { label: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
  { label: 'קריית ים', href: '/areas/kiryat-yam/' },
  { label: 'קריית אתא', href: '/areas/kiryat-ata/' },
  { label: 'נשר', href: '/areas/nesher/' },
  { label: 'טבעון', href: '/areas/tivon/' },
  { label: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
];

const quickLinks = [
  { label: 'כל השירותים', href: '/services/' },
  { label: 'מדריכים וטיפים', href: '/blog/' },
  { label: 'מחירון', href: '/pricing/' },
  { label: 'אודות', href: '/about/' },
  { label: 'צור קשר', href: '/contact/' },
];

const trustBadges = [
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', text: 'טכנאי מוסמך' },
  { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', text: 'מבוטח ומורשה' },
  { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', text: 'הגעה תוך שעתיים' },
];
---

<footer class="bg-brand-900 text-white relative overflow-hidden">
  <!-- Background Decorations -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 start-0 w-[400px] h-[400px] bg-accent-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 end-0 w-[300px] h-[300px] bg-brand-600/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8">

      <!-- Brand Column -->
      <div class="lg:col-span-4">
        <a href="/" class="inline-block mb-5">
          <img
            src="/images/logo.svg"
            alt="פיקס פרו"
            class="h-14 lg:h-16 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          טכנאי מזגנים, אינסטלטור והנדימן מוסמכים בחיפה והקריות.
          15+ שנות ניסיון, מחירים שקופים, אחריות על העבודה.
        </p>

        <!-- Trust Badges -->
        <div class="flex flex-wrap gap-2 mb-5">
          {trustBadges.map((badge) => (
            <div class="flex items-center gap-2 bg-white/5 backdrop-blur-sm rounded-full px-3 py-1.5 border border-white/10">
              <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={badge.icon} />
              </svg>
              <span class="text-xs text-white/80">{badge.text}</span>
            </div>
          ))}
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3 p-4 bg-white/5 rounded-xl border border-white/10">
          <div class="text-center">
            <div class="text-xl font-bold text-accent-500">15+</div>
            <div class="text-xs text-white/50">שנות ניסיון</div>
          </div>
          <div class="text-center border-x border-white/10">
            <div class="text-xl font-bold text-accent-500">2,500+</div>
            <div class="text-xs text-white/50">לקוחות</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-accent-500">24/7</div>
            <div class="text-xs text-white/50">שירות חירום</div>
          </div>
        </div>
      </div>

      <!-- Services Column -->
      <div class="lg:col-span-3">
        <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
          <span>שירותים</span>
          <span class="flex-1 h-px bg-gradient-to-l from-transparent to-accent-500/30"></span>
        </h4>
        <ul class="space-y-2">
          {services.map((item) => (
            <li>
              <a href={item.href} class="group flex items-center gap-2 text-sm text-white/70 hover:text-accent-400 transition-colors">
                <svg class="w-4 h-4 text-accent-500/50 group-hover:text-accent-500 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Areas & Quick Links -->
      <div class="lg:col-span-2">
        <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
          <span>אזורי שירות</span>
          <span class="flex-1 h-px bg-gradient-to-l from-transparent to-accent-500/30"></span>
        </h4>
        <ul class="space-y-1.5 mb-6">
          {areas.slice(0, 5).map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/70 hover:text-accent-400 transition-colors">
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/areas/" class="text-sm text-accent-400 hover:text-accent-300 font-medium">
              כל האזורים ←
            </a>
          </li>
        </ul>

        <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
          <span>ניווט</span>
          <span class="flex-1 h-px bg-gradient-to-l from-transparent to-accent-500/30"></span>
        </h4>
        <ul class="space-y-1.5">
          {quickLinks.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/70 hover:text-accent-400 transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div class="lg:col-span-3">
        <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
          <span>צרו קשר</span>
          <span class="flex-1 h-px bg-gradient-to-l from-transparent to-accent-500/30"></span>
        </h4>

        <!-- Contact Card -->
        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-4 border border-white/10 space-y-3">
          <a href={phoneHref} class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-accent-500/20 group-hover:bg-accent-500 rounded-lg flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-accent-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <span class="text-xs text-white/50 block">טלפון</span>
              <span class="text-white group-hover:text-accent-400 transition-colors font-medium">{phone}</span>
            </div>
          </a>

          <a
            href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 group"
          >
            <div class="w-10 h-10 bg-green-500/20 group-hover:bg-green-500 rounded-lg flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-green-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <span class="text-xs text-white/50 block">וואטסאפ</span>
              <span class="text-white group-hover:text-green-400 transition-colors font-medium">שלחו הודעה</span>
            </div>
          </a>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <span class="text-xs text-white/50 block">שעות פעילות</span>
              <span class="text-white/80 text-sm">א'-ה' 08:00-20:00 | חירום 24/7</span>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href="/contact/"
          class="mt-4 w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-accent-500 hover:bg-accent-600 text-white rounded-lg font-bold transition-all duration-300 hover:shadow-lg hover:shadow-accent-500/20"
        >
          <span>קבלו הצעת מחיר</span>
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Service Areas Strip -->
    <div class="border-t border-white/10 py-4">
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm text-white/50">
        <span class="text-white/70">אזורי שירות:</span>
        {areas.map((area, index) => (
          <>
            <a href={area.href} class="hover:text-accent-400 transition-colors">{area.label}</a>
            {index < areas.length - 1 && <span class="text-white/20">•</span>}
          </>
        ))}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-white/50">
        <p>&copy; {currentYear} פיקס פרו. כל הזכויות שמורות.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/accessibility/" class="hover:text-white transition-colors">הצהרת נגישות</a>
          <a href="/privacy/" class="hover:text-white transition-colors">מדיניות פרטיות</a>
          <a href="/terms/" class="hover:text-white transition-colors">תנאי שימוש</a>
        </div>
      </div>
    </div>
  </div>
</footer>
