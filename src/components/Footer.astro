---
const currentYear = new Date().getFullYear();
const phone = '055-432-9235';
const phoneHref = 'tel:0554329235';

const services = [
  { label: 'מיזוג אוויר', href: '/services/air-conditioning/' },
  { label: 'ניקוי מזגנים', href: '/air-conditioning/cleaning/' },
  { label: 'תיקון מזגנים', href: '/air-conditioning/repair/' },
  { label: 'התקנת מזגנים', href: '/air-conditioning/installation/' },
  { label: 'טכנאי מזגנים', href: '/air-conditioning/technician/' },
  { label: 'אינסטלציה', href: '/services/plumbing/' },
  { label: 'הנדימן', href: '/services/handyman/' },
];

const whatsappNumber = '972554329235';
const whatsappMessage = encodeURIComponent('היי, אשמח לקבל הצעת מחיר');

const areas = [
  { label: 'חיפה', href: '/areas/haifa/' },
  { label: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
  { label: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
  { label: 'קריית ים', href: '/areas/kiryat-yam/' },
  { label: 'קריית אתא', href: '/areas/kiryat-ata/' },
  { label: 'נשר', href: '/areas/nesher/' },
  { label: 'טבעון', href: '/areas/tivon/' },
  { label: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
];

const links = [
  { label: 'כל השירותים', href: '/services/' },
  { label: 'כל האזורים', href: '/areas/' },
  { label: 'מדריכים וטיפים', href: '/blog/' },
  { label: 'אודות', href: '/about/' },
  { label: 'מחירון', href: '/pricing/' },
  { label: 'צור קשר', href: '/contact/' },
];

const trustBadges = [
  { number: '15+', label: 'שנות ניסיון' },
  { number: '2,500+', label: 'לקוחות מרוצים' },
  { number: '24/7', label: 'שירות חירום' },
];
---

<footer class="bg-brand-700 text-white/80">
  <!-- Trust Section -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-3 gap-4 text-center">
        {trustBadges.map((badge) => (
          <div>
            <div class="text-2xl lg:text-3xl font-bold text-accent-500">{badge.number}</div>
            <div class="text-xs lg:text-sm text-white/60">{badge.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand & Contact -->
      <div class="lg:col-span-1">
        <a href="/" class="block mb-4">
          <img
            src="/images/logo.svg"
            alt="פיקס פרו"
            class="h-14 lg:h-16 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-sm text-white/60 mb-4 leading-relaxed">
          טכנאי מזגנים, אינסטלטור והנדימן מוסמכים בחיפה והקריות.
          מחירים שקופים, אחריות על העבודה, הגעה מהירה.
        </p>

        <!-- Contact Methods -->
        <div class="space-y-3 mb-6">
          <a
            href={phoneHref}
            class="flex items-center gap-3 text-white hover:text-accent-400 transition-colors group"
          >
            <span class="flex items-center justify-center w-10 h-10 bg-white/10 rounded-lg group-hover:bg-accent-500 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </span>
            <span class="font-semibold">{phone}</span>
          </a>
          <a
            href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-white hover:text-green-400 transition-colors group"
          >
            <span class="flex items-center justify-center w-10 h-10 bg-white/10 rounded-lg group-hover:bg-green-500 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            <span class="font-semibold">WhatsApp</span>
          </a>
        </div>

        <!-- Business Hours -->
        <div class="text-sm text-white/60">
          <div class="flex items-center gap-2 mb-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-white/80 font-medium">שעות פעילות</span>
          </div>
          <p>א'-ה': 08:00-20:00</p>
          <p>שירות חירום 24/7</p>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">שירותים</h4>
        <ul class="space-y-2 text-sm">
          {services.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Areas -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">אזורי שירות</h4>
        <ul class="space-y-2 text-sm">
          {areas.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">קישורים</h4>
        <ul class="space-y-2 text-sm">
          {links.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Credentials -->
        <div class="mt-6 pt-4 border-t border-white/10">
          <p class="text-xs text-white/50 mb-2">הסמכות מקצועיות:</p>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1 text-xs bg-white/10 px-2 py-1 rounded">
              <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              טכנאי מוסמך
            </span>
            <span class="inline-flex items-center gap-1 text-xs bg-white/10 px-2 py-1 rounded">
              <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              מבוטח
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-white/50">
      <p>&copy; {currentYear} פיקס פרו. כל הזכויות שמורות.</p>
      <div class="flex gap-4">
        <a href="/accessibility/" class="hover:text-white transition-colors">הצהרת נגישות</a>
        <a href="/privacy/" class="hover:text-white transition-colors">מדיניות פרטיות</a>
        <a href="/terms/" class="hover:text-white transition-colors">תנאי שימוש</a>
      </div>
    </div>
  </div>
</footer>
