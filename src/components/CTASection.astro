---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  showPhone?: boolean;
}

const {
  title = 'צריכים טכנאי מזגנים, אינסטלטור או הנדימן?',
  subtitle = 'התקשרו עכשיו - מגיעים לחיפה והקריות תוך שעתיים',
  ctaText = 'השאירו פרטים',
  ctaHref = '#contact',
  showPhone = true,
} = Astro.props;

const phone = '055-432-9235';
---

<!-- CTA Banner - Gradient background with pattern -->
<section class="py-12 md:py-16 bg-gradient-to-br from-brand-800 via-brand-700 to-brand-600 relative overflow-hidden rounded-sm">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.4\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-start">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">
          {title}
        </h2>
        <p class="text-white/80 text-lg">
          {subtitle}
        </p>
      </div>
      <div class="flex items-center">
        <a
          href="tel:0554329235"
          class="inline-flex items-center gap-3 bg-accent-500 text-white px-8 py-4 rounded-sm font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          {phone}
        </a>
      </div>
    </div>
  </div>
</section>
