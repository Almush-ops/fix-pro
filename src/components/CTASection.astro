---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  showPhone?: boolean;
}

const {
  title = 'צריכים טכנאי מזגנים, אינסטלטור או הנדימן?',
  subtitle = 'התקשרו עכשיו - מגיעים לחיפה והקריות תוך שעתיים',
  ctaText = 'השאירו פרטים',
  ctaHref = '#contact',
  showPhone = true,
} = Astro.props;

const phone = '055-432-9235';
---

<!-- CTA Banner - Dark background like Electrician template, Sharp corners -->
<section class="py-12 md:py-16 bg-brand-700">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-start">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">
          {title}
        </h2>
        <p class="text-white/70 text-lg">
          {subtitle}
        </p>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 bg-accent-500 text-white px-8 py-4 font-bold text-lg hover:bg-accent-600 transition-colors"
        >
          {ctaText}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        {showPhone && (
          <a href="tel:0554329235" class="text-white font-bold text-lg hover:text-accent-400 transition-colors flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            {phone}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
