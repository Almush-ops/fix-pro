---
interface Area {
  name: string;
  href: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  areas?: Area[];
}

const {
  title = 'אזורי שירות',
  subtitle = 'טכנאי מזגנים, אינסטלטור והנדימן בכל אזור חיפה והקריות',
  areas = [
    { name: 'חיפה', href: '/areas/haifa/' },
    { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
    { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
    { name: 'קריית ים', href: '/areas/kiryat-yam/' },
    { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
    { name: 'נשר', href: '/areas/nesher/' },
    { name: 'טבעון', href: '/areas/tivon/' },
    { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
  ],
} = Astro.props;
---

<section class="py-16 md:py-20 bg-gradient-to-br from-brand-800 via-brand-700 to-brand-600 relative overflow-hidden rounded-sm">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.2) 1px, transparent 1px), radial-gradient(circle at 75% 75%, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 50px 50px;"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10">
      <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">כיסוי גיאוגרפי</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">{title}</h2>
      <p class="text-white/70 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <!-- Areas Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {areas.map((area) => (
        <a
          href={area.href}
          class="group bg-white/10 hover:bg-accent-500 p-4 text-center transition-all duration-300"
        >
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-accent-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span class="font-semibold text-white">{area.name}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-8">
      <p class="text-white/60 text-sm">
        מגיעים לכל האזורים תוך שעתיים
      </p>
    </div>
  </div>
</section>
