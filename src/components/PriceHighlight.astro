---
interface Props {
  price?: string;
  originalPrice?: string;
  title?: string;
  subtitle?: string;
  features?: string[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  price = '450₪',
  originalPrice = '600-700₪',
  title = 'ניקוי מזגן מיני מרכזי',
  subtitle = 'מבצע מיוחד!',
  features = [
    'פירוק וניקוי מלא',
    'ניקוי פילטרים',
    'בדיקת תקינות',
    'אחריות על העבודה',
  ],
  ctaText = 'הזמינו עכשיו',
  ctaHref = '#contact',
} = Astro.props;
---

<!-- Price Highlight - Electrician style with orange accents -->
<section class="py-16 md:py-20 bg-surface">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="grid md:grid-cols-2">
        <!-- Content -->
        <div class="p-8 lg:p-10">
          <span class="inline-block bg-accent-500 text-white text-sm font-bold px-4 py-1.5 rounded-full mb-4">
            {subtitle}
          </span>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-2">
            {title}
          </h2>
          <p class="text-muted mb-6">
            במקום <span class="line-through text-muted">{originalPrice}</span> בשוק
          </p>

          <ul class="space-y-3 mb-8">
            {features.map((feature) => (
              <li class="flex items-center gap-3 text-dark">
                <div class="w-6 h-6 bg-accent-300/30 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                </div>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 bg-accent-500 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg shadow-accent-500/25"
          >
            {ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
        </div>

        <!-- Price Side -->
        <div class="bg-gradient-to-br from-accent-500 to-accent-600 p-8 lg:p-10 flex flex-col items-center justify-center text-center">
          <span class="text-white/80 text-lg mb-2">רק</span>
          <span class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-2">
            {price}
          </span>
          <span class="text-white/80">כולל מע"מ</span>
        </div>
      </div>
    </div>
  </div>
</section>
