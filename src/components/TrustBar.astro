---
interface Props {
  stats?: { icon: string; value: string; label: string }[];
}

const {
  stats = [
    { icon: 'clock', value: '15+', label: 'שנות ניסיון' },
    { icon: 'check', value: '24/7', label: 'זמינות' },
    { icon: 'money', value: '₪', label: 'מחיר שקוף מראש' },
    { icon: 'fast', value: '2', label: 'שעות להגעה' },
  ],
} = Astro.props;

const icons: Record<string, string> = {
  clock: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  check: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  money: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  fast: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
};
---

<section class="bg-brand-600 py-8 md:py-10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[stat.icon] || icons.check} />
          </div>
          <div class="text-2xl md:text-3xl font-heading font-bold text-white mb-1">
            {stat.value}
          </div>
          <div class="text-sm text-white/70">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
