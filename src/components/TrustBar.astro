---
interface Props {
  stats?: { value: string; label: string }[];
}

const {
  stats = [
    { value: '15+', label: 'שנות ניסיון' },
    { value: '24/7', label: 'זמינות' },
    { value: '₪', label: 'מחיר שקוף מראש' },
    { value: '2', label: 'שעות להגעה' },
  ],
} = Astro.props;
---

<section class="bg-gradient-to-r from-brand-700 via-brand-600 to-brand-700 py-8 md:py-10 relative overflow-hidden rounded-sm">
  <!-- Subtle diagonal lines pattern -->
  <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.1) 10px, rgba(255,255,255,0.1) 20px);"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-2xl md:text-3xl font-heading font-bold text-white mb-1">
            {stat.value}
          </div>
          <div class="text-sm text-white/70">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
