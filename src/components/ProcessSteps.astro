---
interface Step {
  number: number;
  title: string;
  description: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  steps?: Step[];
}

const {
  title = 'איך זה עובד?',
  subtitle = 'תהליך פשוט ושקוף מההתחלה ועד הסוף',
  steps = [
    {
      number: 1,
      title: 'התקשרו או שלחו WhatsApp',
      description: 'ספרו לנו במה אתם צריכים עזרה. נשמח לענות על כל שאלה ולתת הערכה ראשונית.',
    },
    {
      number: 2,
      title: 'קביעת מועד נוח',
      description: 'נתאם מועד שמתאים לכם. אנחנו מגיעים בזמן שנקבע, בלי הפתעות.',
    },
    {
      number: 3,
      title: 'בדיקה והצעת מחיר',
      description: 'נגיע, נבדוק את הבעיה ונציע מחיר שקוף מראש. אתם מחליטים אם להמשיך.',
    },
    {
      number: 4,
      title: 'ביצוע עם אחריות',
      description: 'נבצע את העבודה במקצועיות עם אחריות מלאה. שביעות רצונכם היא המטרה שלנו.',
    },
  ],
} = Astro.props;
---

<!-- Process Steps Section - Electrician style with vertical numbered list -->
<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image Side -->
      <div class="relative">
        <img
          src="/images/gallery/gal-hvac-work-2.webp"
          alt="גל מבצע עבודת מיזוג אוויר"
          class="shadow-xl w-full"
          width="800"
          height="1422"
          loading="lazy"
        />
        <!-- Orange accent - Sharp corners -->
        <div class="absolute -bottom-4 -start-4 w-24 h-24 bg-accent-500 -z-10"></div>
      </div>

      <!-- Steps Side -->
      <div>
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">תהליך העבודה</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-4">{title}</h2>
        <p class="text-muted text-lg mb-10">{subtitle}</p>

        <div class="space-y-8">
          {steps.map((step, index) => (
            <div class="flex gap-6">
              <!-- Number Circle -->
              <div class="relative flex-shrink-0">
                <div class="w-12 h-12 bg-accent-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
                  {step.number}
                </div>
                {/* Vertical connector line */}
                {index < steps.length - 1 && (
                  <div class="absolute top-12 start-1/2 -translate-x-1/2 w-0.5 h-8 bg-accent-300"></div>
                )}
              </div>

              <!-- Content -->
              <div class="pt-1">
                <h3 class="text-lg font-heading font-bold text-dark mb-2">{step.title}</h3>
                <p class="text-muted leading-relaxed">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
