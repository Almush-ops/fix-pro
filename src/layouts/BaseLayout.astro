---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  canonicalUrl?: string;
  noindex?: boolean;
  lang?: string;
  dir?: string;
}

const {
  title,
  description = '',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  noindex = false,
  lang = 'he',
  dir = 'rtl',
} = Astro.props;

const phone = '055-432-9235';
const phoneHref = 'tel:+972554329235';
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-dark antialiased font-sans">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Mobile Sticky Phone CTA (left side - start in RTL) -->
    <a
      href={phoneHref}
      class="fixed bottom-4 start-4 z-50 lg:hidden flex items-center gap-2 bg-accent-500 text-white px-4 py-3 rounded-full shadow-lg shadow-accent-500/30 hover:bg-accent-600 transition-colors"
      aria-label="חייגו עכשיו"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
      <span class="font-semibold text-sm">חייגו</span>
    </a>

    <!-- Accessibility Widget (right side - end in RTL) -->
    <button
      id="accessibility-toggle"
      class="fixed bottom-4 end-4 z-50 w-12 h-12 bg-brand-600 text-white rounded-full shadow-lg hover:bg-brand-700 transition-colors flex items-center justify-center"
      aria-label="הגדרות נגישות"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
        <circle cx="12" cy="4" r="2"/>
        <path d="M19 13v-2c-1.54.02-3.09-.75-4.07-1.83l-1.29-1.43c-.17-.19-.38-.34-.61-.45-.01 0-.01-.01-.02-.01H13c-.35-.2-.75-.3-1.19-.26C10.76 7.11 10 8.04 10 9.09V15c0 1.1.9 2 2 2h5v5h2v-5.5c0-1.1-.9-2-2-2h-3v-3.45c1.29 1.07 3.25 1.94 5 1.95zm-6.17 5c-.41 1.16-1.52 2-2.83 2-1.66 0-3-1.34-3-3 0-1.31.84-2.41 2-2.83V12.1c-2.28.46-4 2.48-4 4.9 0 2.76 2.24 5 5 5 2.42 0 4.44-1.72 4.9-4h-2.07z"/>
      </svg>
    </button>

    <!-- Accessibility Panel -->
    <div
      id="accessibility-panel"
      class="fixed bottom-20 end-4 z-50 hidden bg-white rounded-xl shadow-2xl border border-border p-4 w-72"
    >
      <h3 class="font-heading font-bold text-dark mb-4">הגדרות נגישות</h3>
      <div class="space-y-3">
        <button
          id="acc-font-increase"
          class="w-full flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-brand-50 transition-colors"
        >
          <span>הגדל גופן</span>
          <span class="text-xl font-bold">A+</span>
        </button>
        <button
          id="acc-font-decrease"
          class="w-full flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-brand-50 transition-colors"
        >
          <span>הקטן גופן</span>
          <span class="text-lg">A-</span>
        </button>
        <button
          id="acc-contrast"
          class="w-full flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-brand-50 transition-colors"
        >
          <span>ניגודיות גבוהה</span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18V4c4.41 0 8 3.59 8 8s-3.59 8-8 8z"/>
          </svg>
        </button>
        <button
          id="acc-grayscale"
          class="w-full flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-brand-50 transition-colors"
        >
          <span>גווני אפור</span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.66 7.93L12 2.27 6.34 7.93c-3.12 3.12-3.12 8.19 0 11.31A7.98 7.98 0 0012 21.58c2.05 0 4.1-.78 5.66-2.34 3.12-3.12 3.12-8.19 0-11.31zM12 19.59c-1.6 0-3.11-.62-4.24-1.76C6.62 16.69 6 15.19 6 13.59s.62-3.11 1.76-4.24L12 5.1v14.49z"/>
          </svg>
        </button>
        <button
          id="acc-links"
          class="w-full flex items-center justify-between p-3 bg-surface rounded-lg hover:bg-brand-50 transition-colors"
        >
          <span>הדגש קישורים</span>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
          </svg>
        </button>
        <button
          id="acc-reset"
          class="w-full p-3 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors font-semibold"
        >
          איפוס
        </button>
      </div>
    </div>

    <!-- WhatsApp Popup -->
    <div
      id="whatsapp-popup"
      class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 backdrop-blur-sm"
    >
      <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-heading font-bold text-dark text-lg">שליחת הודעת WhatsApp</h3>
          <button id="whatsapp-close" class="text-muted hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <p class="text-muted text-sm mb-4">השאירו פרטים ונפתח לכם שיחת WhatsApp</p>
        <form id="whatsapp-form" class="space-y-3">
          <input
            type="text"
            name="name"
            required
            placeholder="שם מלא"
            class="w-full px-4 py-3 border border-border rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
          />
          <input
            type="tel"
            name="phone"
            required
            dir="ltr"
            placeholder="050-0000000"
            class="w-full px-4 py-3 border border-border rounded-md text-right focus:outline-none focus:ring-2 focus:ring-green-500"
          />
          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 bg-green-500 text-white py-3 rounded-md font-semibold hover:bg-green-600 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            פתח WhatsApp
          </button>
        </form>
      </div>
    </div>

    <script>
      // Accessibility Widget
      const accToggle = document.getElementById('accessibility-toggle');
      const accPanel = document.getElementById('accessibility-panel');

      accToggle?.addEventListener('click', () => {
        accPanel?.classList.toggle('hidden');
      });

      // Close panel when clicking outside
      document.addEventListener('click', (e) => {
        if (!accToggle?.contains(e.target as Node) && !accPanel?.contains(e.target as Node)) {
          accPanel?.classList.add('hidden');
        }
      });

      // Font size
      let fontSize = 100;
      document.getElementById('acc-font-increase')?.addEventListener('click', () => {
        fontSize = Math.min(fontSize + 10, 150);
        document.documentElement.style.fontSize = fontSize + '%';
      });
      document.getElementById('acc-font-decrease')?.addEventListener('click', () => {
        fontSize = Math.max(fontSize - 10, 80);
        document.documentElement.style.fontSize = fontSize + '%';
      });

      // High contrast
      document.getElementById('acc-contrast')?.addEventListener('click', () => {
        document.body.classList.toggle('high-contrast');
      });

      // Grayscale
      document.getElementById('acc-grayscale')?.addEventListener('click', () => {
        document.body.classList.toggle('grayscale');
      });

      // Highlight links
      document.getElementById('acc-links')?.addEventListener('click', () => {
        document.body.classList.toggle('highlight-links');
      });

      // Reset
      document.getElementById('acc-reset')?.addEventListener('click', () => {
        fontSize = 100;
        document.documentElement.style.fontSize = '100%';
        document.body.classList.remove('high-contrast', 'grayscale', 'highlight-links');
      });

      // WhatsApp Popup
      const whatsappPopup = document.getElementById('whatsapp-popup');
      const whatsappClose = document.getElementById('whatsapp-close');
      const whatsappForm = document.getElementById('whatsapp-form') as HTMLFormElement;

      // Listen for custom event from HeroCardForm
      document.addEventListener('open-whatsapp-popup', () => {
        whatsappPopup?.classList.remove('hidden');
        whatsappPopup?.classList.add('flex');
      });

      whatsappClose?.addEventListener('click', () => {
        whatsappPopup?.classList.add('hidden');
        whatsappPopup?.classList.remove('flex');
      });

      // Close on backdrop click
      whatsappPopup?.addEventListener('click', (e) => {
        if (e.target === whatsappPopup) {
          whatsappPopup?.classList.add('hidden');
          whatsappPopup?.classList.remove('flex');
        }
      });

      whatsappForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(whatsappForm);
        const name = formData.get('name') as string;
        const phone = formData.get('phone') as string;
        const h1 = document.querySelector('h1')?.textContent?.trim() || document.title;

        // Send to webhook first
        try {
          await fetch('https://hook.eu1.make.com/vafte51w7nn4tmtyejfl46cooalp0aru', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              'your-name': name,
              'phone': phone,
              'page-title': h1,
              'website': 'פיקס פרו',
              'category': 'בעלי מקצוע',
            }),
          });
        } catch (error) {
          console.error('Webhook error:', error);
        }

        // Then open WhatsApp
        const message = encodeURIComponent(`שלום, אני ${name}. אשמח לקבל הצעת מחיר.`);
        window.open(`https://wa.me/972554329235?text=${message}`, '_blank');

        // Close popup
        whatsappPopup?.classList.add('hidden');
        whatsappPopup?.classList.remove('flex');
      });
    </script>

    <style is:global>
      /* Accessibility styles */
      .high-contrast {
        filter: contrast(1.5);
      }
      .grayscale {
        filter: grayscale(1);
      }
      .highlight-links a {
        outline: 3px solid #F97316 !important;
        outline-offset: 2px;
      }
    </style>
  </body>
</html>
