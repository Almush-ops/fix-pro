---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'אודות גל לוגסי | טכנאי מזגנים ואינסטלטור בחיפה והקריות';
const description = 'הכירו את גל לוגסי - טכנאי מזגנים מוסמך ואינסטלטור עם 15+ שנות ניסיון בחיפה והקריות. בוגר שנקר, לוחם מילואים ביחידה מובחרת.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אודות גל' },
];

const stats = [
  { value: '15+', label: 'שנות ניסיון' },
  { value: '1,500+', label: 'לקוחות מרוצים' },
  { value: '24/7', label: 'זמינות לחירום' },
  { value: '2 שעות', label: 'זמן הגעה ממוצע' },
];

const values = [
  {
    title: 'מחיר שקוף מראש',
    description: 'לפני שמתחילים, אתם יודעים בדיוק כמה זה יעלה. בלי הפתעות, בלי תוספות פתאומיות.',
  },
  {
    title: 'הגעה מהירה',
    description: 'בעיות בבית לא יכולות לחכות. לכן אני מגיע תוך שעתיים ברוב המקרים.',
  },
  {
    title: 'עבודה נקייה',
    description: 'אני לא משאיר בלגן. כל עבודה מסתיימת בניקיון המקום והשארתו כמו שהיה.',
  },
  {
    title: 'אחריות מלאה',
    description: 'אני עומד מאחורי העבודה שלי. אם יש בעיה, אני חוזר לתקן - בחינם.',
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'גל לוגסי',
  jobTitle: 'טכנאי מזגנים ואינסטלטור מוסמך',
  worksFor: {
    '@type': 'LocalBusiness',
    name: 'פיקס פרו',
    telephone: '+972-55-432-9235',
    url: 'https://fix-pro.co.il',
  },
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'טכנאי מזגנים מוסמך' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'אינסטלטור מוסמך' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'בוגר שנקר - הנדסאי' },
  ],
  knowsAbout: ['מיזוג אוויר', 'אינסטלציה', 'עבודות הנדימן', 'תחזוקת בית'],
};
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero -->
  <PageHero
    title="הכירו את גל לוגסי"
    subtitle="טכנאי מזגנים ואינסטלטור מוסמך עם 15+ שנות ניסיון"
    breadcrumbs={breadcrumbs}
  />

  <!-- Stats Row -->
  <section class="bg-brand-600 py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-heading font-bold text-white mb-1">
              {stat.value}
            </div>
            <div class="text-sm text-white/70">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gal's Story -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div>
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מי אני</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            גל לוגסי - בעל מקצוע מהשטח
          </h2>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>
              שמי גל לוגסי, ואני עוסק במקצוע כבר למעלה מ-15 שנה. התחלתי כשוליה אצל אינסטלטור ותיק בחיפה,
              ובמקביל למדתי טכנאות מיזוג אוויר. עם השנים צברתי ניסיון בכל סוגי העבודות - ממזגן ביתי קטן
              ועד מערכות מיזוג מרכזיות בבניינים גדולים.
            </p>
            <p>
              אני מאמין בשירות ישיר ואמין - בלי משחקים במחירים, בלי להיעלם באמצע עבודה.
              פשוט לענות לטלפון, להגיע בזמן, לעשות את העבודה טוב, ולהיות זמין אם יש בעיה.
            </p>
            <p>
              רוב הלקוחות שלי הם לקוחות חוזרים או הגיעו דרך המלצה.
              זה הדבר הכי חשוב בשבילי - שאנשים סומכים עליי מספיק כדי להמליץ עליי למשפחה ולחברים.
            </p>
          </div>
        </div>

        <!-- Gal at work -->
        <div class="relative">
          <img
            src="/images/gal/gal-hvac-ducting.webp"
            alt="גל לוגסי - טכנאי מזגנים ואינסטלטור בעבודה"
            class="w-full shadow-xl"
            width="800"
            height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -start-4 w-24 h-24 bg-accent-500 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Military Service Section -->
  <section class="py-16 md:py-20 bg-brand-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Certificate Image -->
        <div class="order-2 lg:order-1">
          <img
            src="/images/trust/miluimnik-cert.webp"
            alt="תעודת עסק של מילואימניק - גל לוגסי"
            class="w-full max-w-md mx-auto shadow-2xl"
            width="600"
            height="400"
            loading="lazy"
          />
        </div>

        <!-- Text Content -->
        <div class="order-1 lg:order-2">
          <p class="text-accent-400 font-semibold text-sm uppercase tracking-wide mb-2">שירות למדינה</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-6">
            לוחם מילואים ביחידה מובחרת
          </h2>
          <div class="space-y-4 text-white/80 leading-relaxed">
            <p>
              אני משרת במילואים ביחידה קרבית מובחרת, וזה חלק בלתי נפרד מהזהות שלי.
              המילואים לימדו אותי ערכים שאני מביא גם לעבודה - אחריות, אמינות, והתמודדות עם לחץ.
            </p>
            <p>
              בזמן מלחמה אני נקרא לשרת, ואני גאה לתרום לביטחון המדינה.
              כשאני חוזר הביתה - אני ממשיך לשרת את הקהילה שלי, הפעם דרך העבודה המקצועית.
            </p>
            <p>
              השילוב בין השירות הצבאי לשירות הלקוחות זה משהו שחשוב לי מאוד.
              באותה מידה שאני נלחם עבור המדינה, אני נלחם עבור הלקוחות שלי - שיקבלו שירות הוגן ומקצועי.
            </p>
          </div>
          <div class="mt-8 flex items-center gap-4">
            <div class="w-12 h-12 bg-accent-500 flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <div class="text-white font-bold">עסק של מילואימניק</div>
              <div class="text-white/60 text-sm">מוכר על ידי משרד הביטחון</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Education -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">הסמכות והשכלה</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          בעל מקצוע מוסמך ומבוטח
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Credentials List -->
        <div class="space-y-6">
          <div class="bg-white p-6 flex gap-4 shadow-sm hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-100 flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v18m0-18l-3 3m3-3l3 3m-3 15l-3-3m3 3l3-3M3 12h18M3 12l3-3m-3 3l3 3m15-3l-3-3m3 3l-3 3"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-1">טכנאי מזגנים מוסמך</h3>
              <p class="text-muted text-sm">הסמכה מקצועית לטיפול בכל סוגי מערכות המיזוג - ביתיות, מרכזיות ומסחריות</p>
            </div>
          </div>

          <div class="bg-white p-6 flex gap-4 shadow-sm hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-100 flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-1">אינסטלטור מוסמך</h3>
              <p class="text-muted text-sm">רישיון לביצוע עבודות אינסטלציה בבתים ובעסקים על פי תקנות משרד הבריאות</p>
            </div>
          </div>

          <div class="bg-white p-6 flex gap-4 shadow-sm hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-100 flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-1">בוגר שנקר - הנדסאי</h3>
              <p class="text-muted text-sm">דיפלומה מהמכללה האקדמית שנקר להנדסה ועיצוב</p>
            </div>
          </div>

          <div class="bg-white p-6 flex gap-4 shadow-sm hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-100 flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-1">ביטוח מקצועי</h3>
              <p class="text-muted text-sm">ביטוח אחריות מקצועית וצד שלישי לכל העבודות</p>
            </div>
          </div>
        </div>

        <!-- Diploma Image -->
        <div class="flex items-center justify-center">
          <img
            src="/images/trust/shenkar-diploma.webp"
            alt="דיפלומה מהמכללה האקדמית שנקר - גל לוגסי"
            class="w-full max-w-md shadow-xl"
            width="600"
            height="400"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">העקרונות שלי</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          איך אני עובד
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {values.map((value, index) => (
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-accent-500 flex items-center justify-center shrink-0 text-white font-bold">
              {index + 1}
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-2">{value.title}</h3>
              <p class="text-muted">{value.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Highlights -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">
          15+ שנות ניסיון בשטח
        </h2>
        <p class="text-white/70 max-w-2xl mx-auto">
          במהלך השנים טיפלתי באלפי קריאות שירות, ולמדתי להתמודד עם כל סיטואציה
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">800+</div>
          <div class="text-white/70">התקנות מזגנים</div>
        </div>
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">1,200+</div>
          <div class="text-white/70">תיקונים ושירותים</div>
        </div>
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">150+</div>
          <div class="text-white/70">לקוחות עסקיים</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-4">
        משרת את כל אזור חיפה והקריות
      </h2>
      <p class="text-muted mb-8 max-w-2xl mx-auto">
        אני גר באזור ומכיר אותו היטב. לכן אני יכול להגיע מהר ולתת שירות אישי ללקוחות מקומיים.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((city) => (
          <a
            href={city.href}
            class="px-5 py-3 bg-white text-dark font-medium shadow-sm hover:shadow-md hover:bg-brand-50 transition-all"
          >
            {city.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="רוצים לדבר עם גל?"
    subtitle="התקשרו או השאירו פרטים ואחזור אליכם"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
</BaseLayout>
