---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'אודות פיקס פרו | גל לוגסי - טכנאי מזגנים ואינסטלטור בחיפה';
const description = 'הכירו את גל לוגסי - טכנאי מזגנים מוסמך ואינסטלטור עם 15+ שנות ניסיון בחיפה והקריות. מחיר שקוף, הגעה מהירה, אחריות מלאה.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אודות' },
];

const stats = [
  { value: '15+', label: 'שנות ניסיון' },
  { value: '5,000+', label: 'לקוחות מרוצים' },
  { value: '24/7', label: 'זמינות לחירום' },
  { value: '2 שעות', label: 'זמן הגעה ממוצע' },
];

const certifications = [
  {
    title: 'טכנאי מזגנים מוסמך',
    description: 'הסמכה מקצועית לטיפול בכל סוגי מערכות המיזוג - ביתיות, מרכזיות ומסחריות',
    icon: 'snowflake',
  },
  {
    title: 'אינסטלטור מוסמך',
    description: 'רישיון לביצוע עבודות אינסטלציה בבתים ובעסקים על פי תקנות משרד הבריאות',
    icon: 'wrench',
  },
  {
    title: 'ביטוח מקצועי',
    description: 'ביטוח אחריות מקצועית וצד שלישי לכל העבודות שאנחנו מבצעים',
    icon: 'shield',
  },
  {
    title: 'משרת מילואים פעיל',
    description: 'גאה לשרת במילואים ולתרום לביטחון המדינה לצד השירות ללקוחות',
    icon: 'star',
  },
];

const values = [
  {
    title: 'מחיר שקוף מראש',
    description: 'לפני שמתחילים, אתם יודעים בדיוק כמה זה יעלה. בלי הפתעות, בלי תוספות פתאומיות.',
  },
  {
    title: 'הגעה מהירה',
    description: 'אנחנו יודעים שבעיות בבית לא יכולות לחכות. לכן אנחנו מגיעים תוך שעתיים ברוב המקרים.',
  },
  {
    title: 'עבודה נקייה',
    description: 'אנחנו לא משאירים בלגן. כל עבודה מסתיימת בניקיון המקום והשארתו כמו שהיה.',
  },
  {
    title: 'אחריות מלאה',
    description: 'אנחנו עומדים מאחורי העבודה שלנו. אם יש בעיה, אנחנו חוזרים לתקן - בחינם.',
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'פיקס פרו',
  description: 'שירותי מיזוג אוויר, אינסטלציה והנדימן בחיפה והקריות',
  founder: {
    '@type': 'Person',
    name: 'גל לוגסי',
    jobTitle: 'טכנאי מזגנים ואינסטלטור מוסמך',
  },
  foundingDate: '2010',
  telephone: '+972-55-432-9235',
  url: 'https://fix-pro.co.il',
  areaServed: [
    { '@type': 'City', name: 'חיפה' },
    { '@type': 'City', name: 'קריית ביאליק' },
    { '@type': 'City', name: 'קריית מוצקין' },
    { '@type': 'City', name: 'קריית ים' },
    { '@type': 'City', name: 'קריית אתא' },
    { '@type': 'City', name: 'נשר' },
    { '@type': 'City', name: 'טבעון' },
    { '@type': 'City', name: 'זכרון יעקב' },
  ],
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'טכנאי מזגנים מוסמך' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'אינסטלטור מוסמך' },
  ],
  knowsAbout: ['מיזוג אוויר', 'אינסטלציה', 'עבודות הנדימן', 'תחזוקת בית'],
  priceRange: '₪₪',
};
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero -->
  <PageHero
    title="אודות פיקס פרו"
    subtitle="בעל מקצוע מקומי שמכיר את האזור ואת הלקוחות"
    breadcrumbs={breadcrumbs}
  />

  <!-- Stats Row -->
  <section class="bg-brand-600 py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-heading font-bold text-white mb-1">
              {stat.value}
            </div>
            <div class="text-sm text-white/70">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div>
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">הסיפור שלנו</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            מטכנאי צעיר לבעל מקצוע מבוקש
          </h2>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>
              שמי גל לוגסי, ואני עוסק במקצוע כבר למעלה מ-15 שנה. התחלתי כשוליה אצל אינסטלטור ותיק בחיפה,
              ובמקביל למדתי טכנאות מיזוג אוויר. עם השנים צברתי ניסיון בכל סוגי העבודות - ממזגן ביתי קטן
              ועד מערכות מיזוג מרכזיות בבניינים גדולים.
            </p>
            <p>
              הקמתי את פיקס פרו כי רציתי לתת שירות אחר - כזה שאני בעצמי הייתי רוצה לקבל כלקוח.
              בלי משחקים במחירים, בלי להיעלם באמצע עבודה, ובלי לגרום ללקוח להרגיש שהוא מטריד.
              פשוט לענות לטלפון, להגיע בזמן, לעשות את העבודה טוב, ולהיות זמין אם יש בעיה.
            </p>
            <p>
              היום אני גאה לומר שרוב הלקוחות שלי הם לקוחות חוזרים או הגיעו דרך המלצה.
              זה הדבר הכי חשוב בשבילי - שאנשים סומכים עליי מספיק כדי להמליץ עליי למשפחה ולחברים.
            </p>
          </div>
        </div>

        <!-- Gal at work -->
        <div class="relative">
          <img
            src="/images/gal/gal-hvac-ducting.webp"
            alt="גל לוגסי - טכנאי מזגנים ואינסטלטור בעבודה"
            class="w-full shadow-xl"
            width="800"
            height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -start-4 w-24 h-24 bg-accent-500 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">הסמכות ורישיונות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          בעל מקצוע מוסמך ומבוטח
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {certifications.map((cert) => (
          <div class="bg-white p-6 text-center hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-100 flex items-center justify-center mx-auto mb-4">
              {cert.icon === 'snowflake' && (
                <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v18m0-18l-3 3m3-3l3 3m-3 15l-3-3m3 3l3-3M3 12h18M3 12l3-3m-3 3l3 3m15-3l-3-3m3 3l-3 3"/>
                </svg>
              )}
              {cert.icon === 'wrench' && (
                <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              )}
              {cert.icon === 'shield' && (
                <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              )}
              {cert.icon === 'leaf' && (
                <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
              )}
              {cert.icon === 'star' && (
                <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
              )}
            </div>
            <h3 class="font-heading font-bold text-dark mb-2">{cert.title}</h3>
            <p class="text-muted text-sm">{cert.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">הערכים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          איך אנחנו עובדים
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {values.map((value, index) => (
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-accent-500 flex items-center justify-center shrink-0 text-white font-bold">
              {index + 1}
            </div>
            <div>
              <h3 class="font-heading font-bold text-dark mb-2">{value.title}</h3>
              <p class="text-muted">{value.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Highlights -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">
          15+ שנות ניסיון בשטח
        </h2>
        <p class="text-white/70 max-w-2xl mx-auto">
          במהלך השנים טיפלתי באלפי קריאות שירות, ולמדתי להתמודד עם כל סיטואציה
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">2,000+</div>
          <div class="text-white/70">התקנות מזגנים</div>
        </div>
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">3,500+</div>
          <div class="text-white/70">תיקונים ושירותים</div>
        </div>
        <div class="bg-white/10 p-6 text-center">
          <div class="text-3xl font-heading font-bold text-white mb-2">500+</div>
          <div class="text-white/70">לקוחות עסקיים</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-4">
        משרתים את כל אזור חיפה והקריות
      </h2>
      <p class="text-muted mb-8 max-w-2xl mx-auto">
        אני גר באזור ומכיר אותו היטב. לכן אני יכול להגיע מהר ולתת שירות אישי ללקוחות מקומיים.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((city) => (
          <a
            href={city.href}
            class="px-5 py-3 bg-white text-dark font-medium shadow-sm hover:shadow-md hover:bg-brand-50 transition-all"
          >
            {city.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    title="רוצים לדבר?"
    subtitle="התקשרו או השאירו פרטים ונחזור אליכם"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
</BaseLayout>
