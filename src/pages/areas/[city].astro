---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';
import { cities, type CityData } from '../../data/cities';

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: CityData;
}

const { city } = Astro.props;

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: city.name },
];

const services = [
  {
    title: 'מיזוג אוויר',
    description: city.services.airConditioning,
    image: '/images/gal/gal-tadiran-outdoor.webp',
    href: '/services/air-conditioning/',
    icon: '❄️',
  },
  {
    title: 'אינסטלציה',
    description: city.services.plumbing,
    image: '/images/gal/gal-plumbing-faucet.webp',
    href: '/services/plumbing/',
    icon: '🔧',
  },
  {
    title: 'הנדימן',
    description: city.services.handyman,
    image: '/images/gal/gal-handyman-work.webp',
    href: '/services/handyman/',
    icon: '🛠️',
  },
];

// Schema markup
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://fix-pro.co.il/areas/${city.slug}/#localbusiness`,
  name: 'פיקס פרו',
  alternateName: 'Fix Pro',
  description: `שירותי מיזוג אוויר, אינסטלציה והנדימן ב${city.name}`,
  url: `https://fix-pro.co.il/areas/${city.slug}/`,
  telephone: '+972-55-432-9235',
  priceRange: '₪₪',
  areaServed: {
    '@type': 'City',
    name: city.name,
    ...(city.coordinates && {
      geo: {
        '@type': 'GeoCoordinates',
        latitude: city.coordinates.latitude,
        longitude: city.coordinates.longitude,
      },
    }),
  },
  serviceType: ['מיזוג אוויר', 'אינסטלציה', 'הנדימן'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: city.name,
    addressRegion: 'חיפה',
    addressCountry: 'IL',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '08:00',
      closes: '20:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Friday'],
      opens: '08:00',
      closes: '13:00',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout title={city.metaTitle} description={city.metaDescription}>
  <!-- Hero -->
  <PageHero
    title={city.heroTitle}
    subtitle={city.heroSubtitle}
    breadcrumbs={breadcrumbs}
    showCTA={true}
    ctaText="התקשרו עכשיו"
    ctaHref="tel:+972554329235"
  />

  <!-- Intro Section - Unique Content -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">שירות מקומי</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          {city.intro.headline}
        </h2>
      </div>

      <div class="prose prose-lg max-w-none text-muted leading-relaxed">
        {city.intro.paragraphs.map((paragraph) => (
          <p class="mb-6">{paragraph}</p>
        ))}
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap justify-center gap-4 mt-10">
        <a
          href="tel:+972554329235"
          class="inline-flex items-center gap-2 bg-accent-500 text-white px-8 py-4 font-bold text-lg hover:bg-accent-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          055-432-9235
        </a>
        <a
          href="https://wa.me/972554329235"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-500 text-white px-8 py-4 font-bold text-lg hover:bg-green-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Why We Serve This Area -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">למה אנחנו?</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            {city.whyWeServe.title}
          </h2>
          <p class="text-muted leading-relaxed mb-8">
            {city.whyWeServe.content}
          </p>
          <ul class="space-y-3">
            {city.whyWeServe.highlights.map((highlight) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-dark font-medium">{highlight}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white p-8 shadow-lg">
          <h3 class="text-xl font-heading font-bold text-dark mb-4 flex items-center gap-2">
            <span class="text-2xl">⏱️</span>
            זמני הגעה ל{city.name}
          </h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-gray-100 pb-3">
              <span class="text-muted">קריאה רגילה:</span>
              <span class="font-bold text-dark">{city.responseTime.regular}</span>
            </div>
            <div class="flex justify-between items-center border-b border-gray-100 pb-3">
              <span class="text-muted">קריאת חירום:</span>
              <span class="font-bold text-accent-500">{city.responseTime.emergency}</span>
            </div>
            {city.responseTime.note && (
              <p class="text-sm text-muted italic">{city.responseTime.note}</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services in City - Detailed -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">השירותים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          מה אנחנו מציעים ב{city.name}
        </h2>
      </div>

      <div class="space-y-8">
        {services.map((service, index) => (
          <div class={`flex flex-col md:flex-row gap-8 items-center ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <div class="md:w-1/3">
              <div class="aspect-[4/3] overflow-hidden shadow-lg">
                <img
                  src={service.image}
                  alt={service.title}
                  class="w-full h-full object-cover"
                  width="400"
                  height="300"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="md:w-2/3">
              <h3 class="text-xl md:text-2xl font-heading font-bold text-dark mb-4 flex items-center gap-2">
                <span class="text-2xl">{service.icon}</span>
                {service.title} ב{city.name}
              </h3>
              <p class="text-muted leading-relaxed mb-4">{service.description}</p>
              <a
                href={service.href}
                class="inline-flex items-center gap-2 text-accent-500 font-bold hover:text-accent-600 transition-colors"
              >
                למידע נוסף על {service.title}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Context -->
  <section class="py-16 md:py-20 bg-brand-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold mb-6">
        {city.localContext.title}
      </h2>
      <p class="text-lg leading-relaxed opacity-90">
        {city.localContext.content}
      </p>
    </div>
  </section>

  <!-- Neighborhoods -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">כיסוי מלא</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          שכונות ב{city.name} שאנחנו משרתים
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {city.neighborhoods.map((neighborhood) => (
          <div class="bg-surface p-4 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-bold text-dark mb-1">{neighborhood.name}</h3>
            {neighborhood.description && (
              <p class="text-sm text-muted">{neighborhood.description}</p>
            )}
          </div>
        ))}
      </div>

      <p class="text-center text-muted mt-8">
        לא מצאתם את השכונה שלכם? התקשרו ונבדוק - יש סיכוי טוב שאנחנו מגיעים גם אליכם!
      </p>
    </div>
  </section>

  <!-- Pricing Highlight -->
  <section class="py-12 md:py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white p-8 shadow-lg border-r-4 border-accent-500">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <p class="text-accent-500 font-semibold text-sm mb-2">מבצע מיוחד</p>
            <h3 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-2">
              ניקוי מזגן מיני מרכזי ב-450₪ בלבד
            </h3>
            <p class="text-muted">
              במקום 600-700₪ בשוק | כולל פילטרים ובדיקת תקינות | אותו מחיר בכל {city.name}
            </p>
          </div>
          <a
            href="tel:+972554329235"
            class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-8 py-4 font-bold text-lg hover:bg-accent-600 transition-colors whitespace-nowrap"
          >
            הזמינו עכשיו
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title={`שאלות נפוצות - שירות ב${city.name}`}
    subtitle="תשובות לשאלות שתושבי האזור שואלים"
    faqs={city.faqs}
  />

  <!-- CTA -->
  <CTASection
    title={`צריכים שירות ב${city.name}?`}
    subtitle="התקשרו עכשיו ונגיע במהירות"
  />

  <!-- Contact Form -->
  <section id="contact" class="scroll-mt-20">
    <ContactForm variant="card" />
  </section>

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
