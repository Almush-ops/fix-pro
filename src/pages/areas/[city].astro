---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';

export function getStaticPaths() {
  const cities = [
    {
      slug: 'haifa',
      name: 'חיפה',
      description: 'העיר הגדולה בצפון, כולל שכונות: כרמל, הדר, נווה שאנן, קריית אליעזר, בת גלים, עין הים ועוד.',
      neighborhoods: ['כרמל מערבי', 'כרמל מרכזי', 'הדר', 'נווה שאנן', 'קריית אליעזר', 'בת גלים', 'עין הים', 'רמות רמז', 'דניה'],
    },
    {
      slug: 'kiryat-bialik',
      name: 'קריית ביאליק',
      description: 'עיר מגורים שקטה בלב הקריות, עם שכונות ותיקות וחדשות.',
      neighborhoods: ['מרכז העיר', 'רמת אלון', 'שכונת הותיקים', 'גבעת ים'],
    },
    {
      slug: 'kiryat-motzkin',
      name: 'קריית מוצקין',
      description: 'עיר מגורים פופולרית בקריות עם קרבה לחיפה ולחופי הים.',
      neighborhoods: ['מרכז העיר', 'גבעת מוצקין', 'שכונת הותיקים'],
    },
    {
      slug: 'kiryat-yam',
      name: 'קריית ים',
      description: 'עיר חוף ים מערבית בקריות עם קרבה לחופי הים התיכון.',
      neighborhoods: ['מרכז העיר', 'שכונת הים', 'רמת יגאל'],
    },
    {
      slug: 'kiryat-ata',
      name: 'קריית אתא',
      description: 'עיר תעשייה ומגורים גדולה בקריות עם אוכלוסייה מגוונת.',
      neighborhoods: ['מרכז העיר', 'קריית אתא הירוקה', 'רמת שפרינצק', 'גבעת חיים'],
    },
    {
      slug: 'nesher',
      name: 'נשר',
      description: 'עיר מגורים ירוקה בצמוד לחיפה, על מורדות הכרמל.',
      neighborhoods: ['נשר עילית', 'נשר תחתית', 'רמת יצחק'],
    },
    {
      slug: 'tivon',
      name: 'טבעון',
      description: 'יישוב ירוק ואיכותי על הכרמל, קרוב לחיפה.',
      neighborhoods: ['קריית טבעון', 'אלוני אבא', 'רכסים'],
    },
    {
      slug: 'zichron-yaakov',
      name: 'זכרון יעקב',
      description: 'מושבה היסטורית ויפהפייה עם אווירה ייחודית ונופים מרהיבים.',
      neighborhoods: ['מרכז המושבה', 'רמת הנדיב', 'גבעת עדן'],
    },
  ];

  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;

const title = `טכנאי מזגנים, אינסטלטור והנדימן ב${city.name}`;
const description = `פיקס פרו - שירות מיזוג אוויר, אינסטלציה והנדימן ב${city.name}. הגעה מהירה תוך שעתיים, מחיר שקוף, 15+ שנות ניסיון. ${city.description}`;

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: city.name },
];

const services = [
  {
    title: 'מיזוג אוויר',
    description: `ניקוי, תיקון והתקנת מזגנים ב${city.name}. ניקוי מיני מרכזי ב-450₪ בלבד.`,
    image: '/images/services/air-conditioning.webp',
    href: '/services/air-conditioning/',
  },
  {
    title: 'אינסטלציה',
    description: `שירותי אינסטלציה מקצועיים ב${city.name}. תיקון נזילות, סתימות וכל בעיה.`,
    image: '/images/services/plumbing.webp',
    href: '/services/plumbing/',
  },
  {
    title: 'הנדימן',
    description: `עבודות תחזוקה ותיקונים לבית ב${city.name}. תליית טלוויזיה, הרכבת רהיטים ועוד.`,
    image: '/images/services/handyman.webp',
    href: '/services/handyman/',
  },
];

const faqs = [
  {
    question: `כמה זמן לוקח לכם להגיע ל${city.name}?`,
    answer: `אנחנו מגיעים ל${city.name} תוך שעתיים מרגע הקריאה. לקריאות חירום (נזילות, סתימות) - אנחנו מתאמצים להגיע מהר יותר.`,
  },
  {
    question: `באילו שכונות ב${city.name} אתם עובדים?`,
    answer: `אנחנו מספקים שירות בכל השכונות ב${city.name}: ${city.neighborhoods.join(', ')}. אם השכונה שלכם לא ברשימה - התקשרו ונבדוק.`,
  },
  {
    question: 'האם יש תוספת מחיר להגעה?',
    answer: `לא! אין תוספת להגעה ל${city.name}. המחיר שאנחנו נותנים הוא המחיר הסופי - בלי הפתעות.`,
  },
  {
    question: 'אתם עובדים גם בסופי שבוע?',
    answer: 'אנחנו זמינים 24/7 לקריאות חירום, כולל שבתות וחגים. לעבודות רגילות - ימים א-ה, 08:00-20:00.',
  },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'פיקס פרו',
  description: `שירותי מיזוג אוויר, אינסטלציה והנדימן ב${city.name}`,
  telephone: '+972-55-432-9235',
  url: `https://fix-pro.co.il/areas/${city.slug}/`,
  areaServed: {
    '@type': 'City',
    name: city.name,
  },
  serviceType: ['מיזוג אוויר', 'אינסטלציה', 'הנדימן'],
  priceRange: '₪₪',
  address: {
    '@type': 'PostalAddress',
    addressLocality: city.name,
    addressRegion: 'חיפה',
    addressCountry: 'IL',
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero -->
  <PageHero
    title={`שירות ב${city.name}`}
    subtitle={`מיזוג אוויר, אינסטלציה והנדימן - הגעה מהירה ומחיר שקוף`}
    breadcrumbs={breadcrumbs}
  />

  <!-- Intro -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">שירות מקומי</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
        טכנאי מזגנים, אינסטלטור והנדימן ב{city.name}
      </h2>
      <p class="text-muted text-lg leading-relaxed mb-8">
        {city.description} אנחנו מספקים שירות מקצועי ואמין לכל תושבי {city.name} והאזור.
        הגעה מהירה תוך שעתיים, מחיר שקוף מראש, ואחריות מלאה על כל עבודה.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 bg-accent-500 text-white px-8 py-4 font-bold text-lg hover:bg-accent-600 transition-colors"
        >
          קבלו הצעת מחיר
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        <a
          href="tel:+972554329235"
          class="inline-flex items-center gap-2 border-2 border-brand-600 text-brand-600 px-8 py-4 font-bold text-lg hover:bg-brand-600 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          055-432-9235
        </a>
      </div>
    </div>
  </section>

  <!-- Services in City -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">השירותים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">
          מה אנחנו מציעים ב{city.name}
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="group bg-white overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="400"
                height="300"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-heading font-bold text-dark mb-3">{service.title}</h3>
              <p class="text-muted leading-relaxed mb-5 text-sm">{service.description}</p>
              <a
                href={service.href}
                class="inline-flex items-center gap-2 text-accent-500 font-bold text-sm hover:text-accent-600 transition-colors group"
              >
                למידע נוסף
                <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Neighborhoods -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">כיסוי מלא</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-8">
        שכונות ב{city.name} שאנחנו משרתים
      </h2>
      <div class="flex flex-wrap justify-center gap-3">
        {city.neighborhoods.map((neighborhood) => (
          <span class="px-4 py-2 bg-surface text-dark font-medium shadow-sm">
            {neighborhood}
          </span>
        ))}
      </div>
      <p class="text-muted mt-6">
        לא מצאתם את השכונה שלכם? התקשרו ונבדוק - יש סיכוי טוב שאנחנו מגיעים גם אליכם!
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title={`שאלות נפוצות - שירות ב${city.name}`}
    subtitle="תשובות לשאלות הנפוצות ביותר"
    faqs={faqs}
  />

  <!-- CTA -->
  <CTASection
    title={`צריכים שירות ב${city.name}?`}
    subtitle="התקשרו עכשיו ונגיע תוך שעתיים"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Local Business Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</BaseLayout>
