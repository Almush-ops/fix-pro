---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';

const title = 'אזורי שירות';
const description = 'פיקס פרו מספק שירותי מיזוג אוויר, אינסטלציה והנדימן בחיפה והקריות. חיפה, קריית ביאליק, קריית מוצקין, קריית ים, קריית אתא, נשר, טבעון, זכרון יעקב.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות' },
];

const areas = [
  { name: 'חיפה', href: '/areas/haifa/' },
  { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
  { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
  { name: 'קריית ים', href: '/areas/kiryat-yam/' },
  { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
  { name: 'נשר', href: '/areas/nesher/' },
  { name: 'טבעון', href: '/areas/tivon/' },
  { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
];
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero -->
  <PageHero
    title="אזורי שירות"
    subtitle="אנחנו מספקים שירות בכל אזור חיפה והקריות עם הגעה מהירה תוך שעתיים"
    breadcrumbs={breadcrumbs}
  />

  <!-- Areas Grid -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {areas.map((area) => (
          <a
            href={area.href}
            class="group bg-surface p-6 text-center hover:bg-brand-50 border border-transparent hover:border-brand-200 transition-all shadow-sm hover:shadow-lg"
          >
            <div class="w-12 h-12 mx-auto bg-brand-600 flex items-center justify-center mb-3 group-hover:bg-accent-500 transition-colors">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h2 class="font-heading font-bold text-dark group-hover:text-brand-600 transition-colors">
              {area.name}
            </h2>
          </a>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-muted mb-4">לא מצאתם את האזור שלכם? התקשרו ונבדוק אם אנחנו מגיעים אליכם</p>
        <a
          href="tel:+972554329235"
          class="inline-flex items-center gap-2 text-accent-500 font-bold hover:text-accent-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          055-432-9235
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection />

  <!-- Contact Form -->
  <ContactForm variant="card" />
</BaseLayout>
