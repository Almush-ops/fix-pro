---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const title = 'מדריכים וטיפים | פיקס פרו';
const description = 'מדריכים מקצועיים וטיפים שימושיים בנושאי מיזוג אוויר, אינסטלציה ותחזוקת הבית. מאת גל מפיקס פרו.';

// Get all blog posts sorted by date (newest first)
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['מיזוג-אוויר', 'אינסטלציה', 'הנדימן', 'טיפים'] as const;

const categoryLabels: Record<string, string> = {
  'מיזוג-אוויר': 'מיזוג אוויר',
  'אינסטלציה': 'אינסטלציה',
  'הנדימן': 'הנדימן',
  'טיפים': 'טיפים כלליים',
};
---

<BaseLayout title={title} description={description}>
  <section class="py-16 md:py-20 bg-brand-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-dark mb-4">
        מדריכים וטיפים
      </h1>
      <p class="text-lg text-muted">
        מאמרים מקצועיים בנושאי מיזוג אוויר, אינסטלציה ותחזוקת הבית
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="group rounded-xl overflow-hidden bg-white border border-border hover:border-brand-200 hover:shadow-lg transition-all">
              {post.data.image && (
                <a href={`/blog/${post.slug}/`} class="block">
                  <div class="aspect-[16/9] overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      width="400"
                      height="225"
                    />
                  </div>
                </a>
              )}
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="bg-brand-100 text-brand-700 px-2 py-0.5 rounded text-xs font-medium">
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <time class="text-sm text-muted">
                    {post.data.date.toLocaleDateString('he-IL', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </div>
                <h2 class="text-xl font-heading font-semibold text-dark group-hover:text-brand-600 transition-colors leading-tight">
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="mt-3 text-muted line-clamp-3 text-sm">
                  {post.data.description}
                </p>
                <a
                  href={`/blog/${post.slug}/`}
                  class="inline-flex items-center gap-1 mt-4 text-brand-600 font-medium text-sm hover:text-brand-700 transition-colors"
                >
                  קראו עוד
                  <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>
          <h2 class="text-xl font-heading font-bold text-dark mb-2">בקרוב - מדריכים ומאמרים</h2>
          <p class="text-muted max-w-md mx-auto">
            אנחנו עובדים על מדריכים מקצועיים שיעזרו לכם לתחזק את הבית. בינתיים, אתם מוזמנים ליצור קשר לכל שאלה.
          </p>
        </div>
      )}
    </div>
  </section>

  <CTASection />
</BaseLayout>
