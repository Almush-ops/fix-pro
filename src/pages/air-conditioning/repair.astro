---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';

const title = 'תיקון מזגנים בחיפה | שירות 24/7 | פיקס פרו';
const description = 'תיקון מזגנים בחיפה והקריות עם הגעה מהירה. טכנאי מזגנים מוסמך לכל התקלות - מילוי גז, תיקון דליפות, החלפת רכיבים. שירות חירום 24/7!';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'מיזוג אוויר', href: '/services/air-conditioning/' },
  { label: 'תיקון מזגנים' },
];

const commonRepairs = [
  {
    title: 'מזגן לא מקרר',
    description: 'התקלה הנפוצה ביותר. יכולה לנבוע מחוסר גז, פילטרים סתומים, בעיה במדחס או בעיה חשמלית. אבחנה מדויקת חיונית לתיקון נכון.',
    price: 'קריאה 250₪',
    urgency: 'תלוי בגורם',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'נזילת מים מהמזגן',
    description: 'בדרך כלל נגרמת מסתימה בצינור הניקוז או בעיה במשאבת הניקוז. לעתים קרובות הבעיה פשוטה לתיקון, אבל אם מתעלמים ממנה היא יכולה לגרום נזק לקירות.',
    price: 'קריאה 250₪',
    urgency: 'דחוף',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    title: 'מזגן מוציא רעש',
    description: 'רעשים יכולים להיגרם ממנוע שחוק, מפוח לא מאוזן, רכיב רופף או בעיה ביחידה החיצונית. סוג הרעש עוזר לאבחן את הבעיה.',
    price: 'קריאה 250₪',
    urgency: 'בינוני',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg>`,
  },
  {
    title: 'מילוי גז למזגן',
    description: 'ירידה בכמות הגז גורמת לירידה ביעילות הקירור. אם צריך למלא גז באופן תדיר - יש דליפה שצריך לאתר ולתקן. אנחנו משתמשים בגזים מאושרים בלבד.',
    price: '450₪',
    urgency: 'בינוני',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    title: 'תיקון שלט רחוק',
    description: 'בעיות בשלט - לא עובד, לא מגיב, תצוגה לא פועלת. לפעמים מספיק להחליף סוללות, לפעמים צריך תיכנות מחדש או החלפת השלט.',
    price: '130-150₪',
    urgency: 'נמוך',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'החלפת מדחס',
    description: 'המדחס הוא הלב של המזגן. כשהוא נשרף - צריך להחליף. זה תיקון יקר, ולפעמים משתלם יותר לקנות מזגן חדש. אנחנו נייעץ לכם בכנות.',
    price: 'מ-1,500₪',
    urgency: 'דחוף',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
];

const pricingTable = [
  { service: 'קריאת שירות/אבחון', price: '250₪', note: 'מקוזז מעלות התיקון' },
  { service: 'מילוי גז', price: '450₪', note: 'כל סוגי הגזים' },
  { service: 'תיקון נזילה', price: '350-450₪', note: 'תלוי במיקום' },
  { service: 'החלפת מנוע/כרטיס/מדחס', price: 'הצעת מחיר', note: 'תלוי במזגן' },
  { service: 'קריאת חירום (אחרי 20:00)', price: '350₪', note: 'כולל אבחון' },
];

const brands = [
  'אלקטרה', 'תדיראן', 'אמקור', 'מיצובישי', 'דייקין',
  'גרי', 'האייר', 'LG', 'סמסונג', 'טושיבה',
  'פנסוניק', 'קאריר', 'מידאה', 'פוג\'יטסו', 'היטאצ\'י',
];

const faqs = [
  {
    question: 'המזגן לא מקרר - מה יכולה להיות הסיבה?',
    answer: 'יש כמה סיבות אפשריות: חוסר בגז קירור (הסיבה הנפוצה ביותר), פילטרים סתומים שחוסמים את זרימת האוויר, בעיה במדחס, או תקלה חשמלית בכרטיס הבקרה. רק אבחון מקצועי יכול לזהות את הבעיה המדויקת. אנחנו מגיעים עם כל הציוד לאבחון במקום.',
  },
  {
    question: 'כמה עולה מילוי גז למזגן?',
    answer: 'מילוי גז למזגן עולה 450₪ (לפני מע"מ). חשוב לדעת: אם המזגן צריך מילוי גז תכוף - יש דליפה שצריך לאתר ולתקן. אחרת, הגז שימלאו יידלוף שוב. אנחנו תמיד מחפשים דליפות לפני מילוי גז.',
  },
  {
    question: 'מתי כדאי לתקן ומתי להחליף מזגן?',
    answer: 'ככלל אצבע: אם עלות התיקון עולה על 40-50% ממחיר מזגן חדש מקביל, עדיף להחליף. גם אם המזגן ישן מ-10-12 שנים, לפעמים עדיף להחליף - מזגנים חדשים יעילים יותר וחוסכים בחשמל. אנחנו תמיד מייעצים בכנות ולא "מוכרים" תיקונים מיותרים.',
  },
  {
    question: 'האם יש אחריות על התיקון?',
    answer: 'כן! על עבודה - אחריות של 3 חודשים. על חלקי חילוף חדשים - אחריות יצרן (בדרך כלל שנה). אם התקלה חוזרת באותו רכיב בתוך תקופת האחריות - נתקן חינם.',
  },
  {
    question: 'יש שירות חירום לתיקון מזגנים?',
    answer: 'כן, אנחנו מספקים שירות חירום 24/7. בימי חול רגילים הגעה תוך שעה. קריאת שירות עולה 250₪ (לפני מע"מ), מקוזז מעלות התיקון.',
  },
  {
    question: 'למה המזגן נוזל מים?',
    answer: 'נזילת מים מהמזגן נגרמת בדרך כלל מסתימה בצינור הניקוז - לכלוך, אבק או אצות שמצטברים עם הזמן. לפעמים המשאבה שמנקזת את המים לא עובדת כמו שצריך. זה תיקון פשוט יחסית, אבל חשוב לטפל בזה מהר כי מים יכולים לגרום נזק לקירות ולרהיטים.',
  },
];

const repairSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'תיקון מזגנים',
  description: 'שירות תיקון מזגנים מקצועי בחיפה והקריות - כל סוגי התקלות, שירות חירום 24/7',
  provider: {
    '@type': 'LocalBusiness',
    name: 'פיקס פרו',
    telephone: '+972-55-432-9235',
    areaServed: 'חיפה והקריות',
  },
  areaServed: {
    '@type': 'City',
    name: 'חיפה',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'תיקוני מזגנים',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'אבחון תקלה' },
        price: '250',
        priceCurrency: 'ILS',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'מילוי גז' },
        price: '450',
        priceCurrency: 'ILS',
      },
    ],
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <PageHero
    title="תיקון מזגנים בחיפה והקריות"
    subtitle="המזגן לא מקרר? נוזל? מוציא רעש? הגעה מהירה תוך שעה, תיקון מקצועי עם אחריות"
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/services/air-conditioning.webp"
  />

  <!-- Emergency Banner -->
  <section class="bg-red-600 py-4">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 text-white text-center">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 flex items-center justify-center animate-pulse">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="text-start">
            <p class="font-bold text-lg">שירות חירום 24/7</p>
            <p class="text-white/80 text-sm">הגעה תוך שעה • כל ימות השבוע</p>
          </div>
        </div>
        <a href="tel:0554329235" class="bg-white text-red-600 px-8 py-3 font-bold hover:bg-red-50 transition-colors">
          055-432-9235
        </a>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-muted">
        <p class="text-lg leading-relaxed">
          המזגן הפסיק לעבוד באמצע הקיץ החם? יש רעש מוזר מהיחידה החיצונית? נזילת מים שמרטיבה את הקיר?
          אלה הרגעים שבהם צריך טכנאי מזגנים אמין ומקצועי - ואנחנו כאן בשבילכם.
        </p>
        <p>
          פיקס פרו מספקת שירות תיקון מזגנים בכל אזור חיפה והקריות עם הגעה מהירה תוך שעה. אנחנו מתקנים את כל סוגי המזגנים -
          עיליים (Split), מיני מרכזי, מרכזי ומסחרי - ועובדים עם כל המותגים המובילים בשוק.
        </p>
        <p>
          הצוות שלנו מצויד בכל הכלים והחלקים הנדרשים לתיקון במקום, כולל מכשיר מילוי גז מדויק, ציוד איתור דליפות,
          ומלאי של חלקי חילוף נפוצים. רוב התקלות נפתרות בביקור אחד - בלי צורך לחכות לחלקים או לקבוע ביקור נוסף.
        </p>
        <p>
          אנחנו מאמינים בשקיפות מלאה. לפני כל תיקון נסביר בדיוק מה הבעיה ומה העלות. אם התיקון לא משתלם כלכלית - נגיד לכם את האמת
          ונציע חלופות. אנחנו לא "מוכרים" תיקונים מיותרים.
        </p>
      </div>
    </div>
  </section>

  <!-- Common Repairs -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">תקלות נפוצות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">תקלות מזגן שאנחנו מתקנים</h2>
        <p class="text-muted max-w-2xl mx-auto">רוב התקלות נפתרות בביקור אחד עם אחריות מלאה</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {commonRepairs.map((repair) => (
          <div class="bg-white p-6 shadow-sm hover:shadow-lg transition-all duration-300 group">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-brand-100 group-hover:bg-brand-600 flex items-center justify-center shrink-0 transition-colors">
                <div class="text-brand-600 group-hover:text-white transition-colors" set:html={repair.icon} />
              </div>
              <div class="flex-1">
                <h3 class="font-heading font-bold text-dark mb-2">{repair.title}</h3>
                <p class="text-muted text-sm mb-3">{repair.description}</p>
                <div class="flex items-center gap-4 text-sm">
                  <span class="text-brand-600 font-bold">{repair.price}</span>
                  <span class={`px-2 py-0.5 text-xs ${repair.urgency === 'דחוף' ? 'bg-red-100 text-red-700' : repair.urgency === 'בינוני' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'}`}>
                    {repair.urgency}
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מחירון</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מחירון תיקון מזגנים</h2>
        <p class="text-muted">מחירים שקופים • ללא הפתעות • הצעת מחיר לפני התיקון</p>
      </div>

      <div class="bg-surface overflow-hidden shadow-sm">
        <table class="w-full">
          <thead class="bg-brand-600 text-white">
            <tr>
              <th class="text-start py-4 px-6 font-heading font-bold">שירות</th>
              <th class="text-start py-4 px-4 font-heading font-bold">מחיר</th>
              <th class="text-start py-4 px-6 font-heading font-bold hidden sm:table-cell">הערות</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {pricingTable.map((row, index) => (
              <tr class={index % 2 === 0 ? 'bg-white' : 'bg-surface'}>
                <td class="py-4 px-6 text-dark">{row.service}</td>
                <td class="py-4 px-4 text-brand-600 font-bold whitespace-nowrap">{row.price}</td>
                <td class="py-4 px-6 text-muted text-sm hidden sm:table-cell">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-center text-muted text-sm mt-4">
        * המחירים כוללים מע"מ ואחריות על העבודה. מחיר סופי נקבע לאחר אבחון.
      </p>
    </div>
  </section>

  <!-- Emergency Service Section -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent-400 font-semibold text-sm uppercase tracking-wide mb-2">שירות חירום</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-6">
            תיקון מזגנים 24/7 - גם בלילה ובסוף שבוע
          </h2>
          <div class="space-y-4 text-white/80">
            <p>
              מזגן שמתקלקל לא מחכה לשעות נוחות. לכן אנחנו מציעים שירות חירום 24 שעות ביממה, 7 ימים בשבוע -
              כולל לילות, שבתות וחגים.
            </p>
            <p>
              בימי חול רגילים (08:00-20:00) - הגעה תוך שעה ללא תוספת תשלום.
              בשעות הערב והלילה, בשבתות ובחגים - תוספת של 100₪ בלבד לעלות התיקון.
            </p>
          </div>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="tel:0554329235" class="inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-6 py-3 font-bold hover:bg-accent-600 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              055-432-9235
            </a>
            <a href="/contact/" class="inline-flex items-center justify-center gap-2 bg-white text-brand-700 px-6 py-3 font-bold hover:bg-brand-50 transition-colors">
              השאירו פרטים
            </a>
          </div>
        </div>
        <div class="bg-white/10 p-8">
          <h3 class="text-xl font-heading font-bold text-white mb-6">למה לבחור בנו לשירות חירום?</h3>
          <ul class="space-y-4">
            {[
              'הגעה מהירה תוך שעה לכל אזור חיפה והקריות',
              'טכנאי מצויד בכל הכלים והחלקים לתיקון במקום',
              'מחיר שקוף מראש - ללא הפתעות',
              'אחריות מלאה על העבודה',
              'תוספת סבירה בלבד לקריאות לילה/שבת',
            ].map((item) => (
              <li class="flex items-center gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands We Service -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מותגים</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מתקנים כל מותג</h2>
        <p class="text-muted">מומחים בתיקון כל מותגי המזגנים המובילים</p>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        {brands.map((brand) => (
          <div class="bg-white px-6 py-3 shadow-sm text-dark font-medium">
            {brand}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">תיקון מזגנים בכל הצפון</h2>
        <p class="text-muted">הגעה מהירה לכל חיפה והקריות</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((area) => (
          <a
            href={area.href}
            class="group bg-surface hover:bg-brand-600 p-4 text-center transition-all duration-300"
          >
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-brand-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span class="font-semibold text-dark group-hover:text-white transition-colors">{area.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title="שאלות נפוצות על תיקון מזגנים"
    subtitle="תשובות לשאלות הנפוצות ביותר"
    faqs={faqs}
  />

  <!-- CTA -->
  <CTASection
    title="המזגן לא עובד?"
    subtitle="התקשרו עכשיו - הגעה תוך שעה!"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(repairSchema)} />
</BaseLayout>
