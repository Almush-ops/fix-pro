---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';

const title = 'אינסטלטור בחיפה והקריות';
const description = 'שירותי אינסטלציה מקצועיים בחיפה והקריות. תיקון נזילות, פתיחת סתימות, החלפת ברזים, התקנת אסלות ותיקון דודי שמש. הגעה תוך שעתיים.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'אינסטלציה' },
];

const services = [
  {
    title: 'תיקון נזילות',
    description: 'איתור ותיקון נזילות בצנרת, ברזים, אסלות וכיורים. שימוש בציוד מקצועי לאיתור נזילות סמויות.',
    price: 'החל מ-150₪',
  },
  {
    title: 'פתיחת סתימות',
    description: 'פתיחת סתימות בכיורים, אסלות, מקלחות וצנרת ביוב. שימוש בספירלה חשמלית ובמקרים מורכבים - מצלמת ביוב.',
    price: 'החל מ-200₪',
  },
  {
    title: 'החלפת ברזים',
    description: 'התקנה והחלפה של ברזים במטבח, בחדר האמבטיה ובמרפסת. עבודה נקייה ומקצועית.',
    price: 'החל מ-180₪',
  },
  {
    title: 'התקנת אסלות וכיורים',
    description: 'התקנת אסלות סמויות ורגילות, כיורים, ארונות אמבטיה וברזים. כולל חיבור לצנרת וביוב.',
    price: 'החל מ-350₪',
  },
  {
    title: 'תיקון דודי שמש',
    description: 'תיקון ותחזוקת דודי שמש - החלפת אלמנט, תרמוסטט, מצופים ואביזרים. בדיקת תקינות המערכת.',
    price: 'החל מ-250₪',
  },
  {
    title: 'התקנת מכונות כביסה',
    description: 'חיבור מכונות כביסה ומדיחי כלים לצנרת המים והביוב. הכנת תשתית לפי הצורך.',
    price: 'החל מ-150₪',
  },
];

const faqs = [
  {
    question: 'יש לי נזילה בקיר - מה עושים?',
    answer: 'נזילה בקיר דורשת טיפול מיידי כדי למנוע נזקים. אנחנו מגיעים עם ציוד לאיתור נזילות סמויות, מאתרים את מקור הבעיה ומתקנים עם מינימום נזק לקיר.',
  },
  {
    question: 'האסלה שלי סתומה - אפשר לפתור את זה?',
    answer: 'בהחלט! רוב הסתימות באסלות נפתרות במקום. אנחנו משתמשים בספירלה חשמלית שפותחת סתימות עמוקות. במקרים קשים יש לנו גם מצלמת ביוב לאבחון מדויק.',
  },
  {
    question: 'כמה עולה להחליף ברז במטבח?',
    answer: 'החלפת ברז במטבח מתחילה מ-180₪ לעבודה (לא כולל הברז עצמו). אם יש צורך בהתאמות נוספות, נציע מחיר מראש.',
  },
  {
    question: 'הדוד שמש לא מחמם - מה הבעיה?',
    answer: 'כמה סיבות אפשריות: אלמנט שרוף, תרמוסטט תקול, בעיה במצוף או אבנית בדוד. אנחנו מבצעים בדיקה במקום ונותנים אבחנה ומחיר לפני התיקון.',
  },
  {
    question: 'אתם עובדים בשעות חירום?',
    answer: 'כן! אנחנו זמינים 24/7 לקריאות חירום - נזילות, סתימות, פיצוצי צנרת. בשעות לא שגרתיות יש תוספת למחיר.',
  },
];

const plumbingSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'שירותי אינסטלציה',
  description: 'שירותי אינסטלציה מקצועיים בחיפה והקריות - תיקון נזילות, פתיחת סתימות, התקנות',
  provider: {
    '@type': 'LocalBusiness',
    name: 'פיקס פרו',
    telephone: '+972-55-432-9235',
    areaServed: 'חיפה והקריות',
  },
  areaServed: {
    '@type': 'City',
    name: 'חיפה',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'שירותי אינסטלציה',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.description,
      },
    })),
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero with Emergency Emphasis -->
  <PageHero
    title="אינסטלטור בחיפה והקריות"
    subtitle="תיקון נזילות, פתיחת סתימות, שירות 24/7 לקריאות חירום - מגיעים תוך שעתיים!"
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/services/plumbing.webp"
    showCTA={true}
    ctaText="התקשרו עכשיו"
    ctaHref="tel:0554329235"
    phoneText="055-432-9235"
  />

  <!-- Emergency Notice -->
  <section class="bg-red-600 py-4">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 text-white">
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 animate-pulse" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span class="font-bold text-lg">חירום? זמינים 24/7!</span>
        </div>
        <span>נזילה, סתימה, פיצוץ צנרת - מגיעים גם בלילה ובסופ"ש</span>
        <a href="tel:0554329235" class="bg-white text-red-600 px-6 py-2 font-bold hover:bg-red-50 transition-colors">
          055-432-9235
        </a>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-muted">
        <p class="text-lg leading-relaxed">
          מחפשים אינסטלטור מקצועי בחיפה או בקריות? אנחנו מספקים שירותי אינסטלציה מקיפים לבית ולעסק -
          תיקון נזילות, פתיחת סתימות, החלפת ברזים, התקנת אסלות וכיורים, ותיקון דודי שמש.
          ההגעה מהירה, המחיר שקוף מראש, והעבודה מתבצעת עם אחריות מלאה.
        </p>
        <p>
          בעיות אינסטלציה יכולות להפוך לבלאגן גדול אם לא מטפלים בהן בזמן. נזילה קטנה יכולה לגרום לנזקי רטיבות,
          וסתימה יכולה להפוך לגלישה. לכן אנחנו זמינים 24/7 לקריאות חירום - נזילות, סתימות ופיצוצי צנרת.
        </p>
        <p>
          אנחנו משרתים את כל אזור חיפה והקריות - חיפה, קריית ביאליק, קריית מוצקין, קריית ים, קריית אתא,
          נשר, טבעון וזכרון יעקב. הגעה תוך שעתיים ברוב המקרים, ובמקרי חירום - מהר יותר.
        </p>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">השירותים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">שירותי אינסטלציה</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <div class="bg-surface p-6 shadow-sm hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-heading font-bold text-dark mb-2">{service.title}</h3>
            <p class="text-muted text-sm mb-4">{service.description}</p>
            <div class="flex items-center justify-between pt-4 border-t border-border">
              <span class="font-bold text-brand-600">{service.price}</span>
              <a href="/contact/" class="text-accent-500 font-semibold text-sm hover:text-accent-600 transition-colors">
                הזמינו עכשיו ←
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">למה אנחנו</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            אינסטלטור מקצועי ואמין
          </h2>
          <div class="space-y-4 text-muted">
            <p>
              בעיות אינסטלציה יכולות להפוך למטרד רציני אם לא מטפלים בהן בזמן.
              אנחנו מגיעים מהר, מאתרים את הבעיה ומתקנים אותה במקצועיות.
            </p>
            <p>
              אנחנו מאמינים בעבודה נקייה - לא משאירים בלגן אחרינו.
              כל עבודה מתבצעת עם אחריות מלאה ובמחיר שקוף שנקבע מראש.
            </p>
          </div>
          <ul class="mt-6 space-y-3">
            {['הגעה מהירה לקריאות חירום', 'מחיר שקוף לפני תחילת העבודה', 'עבודה נקייה ומסודרת', 'אחריות על כל תיקון'].map((item) => (
              <li class="flex items-center gap-3">
                <div class="w-6 h-6 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-dark">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative order-1 lg:order-2">
          <img
            src="/images/gal/gal-plumbing-faucet.webp"
            alt="גל לוגסי - אינסטלטור מוסמך מתקן ברז"
            class="shadow-xl w-full"
            width="800"
            height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -end-4 w-24 h-24 bg-accent-500 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מחירון</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מחירון שירותי אינסטלציה</h2>
        <p class="text-muted">מחירים שקופים ללא הפתעות. המחיר הסופי נקבע לפני תחילת העבודה</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full bg-surface shadow-sm">
          <thead class="bg-brand-700 text-white">
            <tr>
              <th class="text-start py-4 px-6 font-heading font-bold">שירות</th>
              <th class="text-start py-4 px-6 font-heading font-bold">מחיר</th>
              <th class="text-start py-4 px-6 font-heading font-bold">הערות</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">תיקון נזילה פשוטה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">150₪</td>
              <td class="py-4 px-6 text-muted text-sm">ברז, צינור חשוף</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">איתור נזילה סמויה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-250₪</td>
              <td class="py-4 px-6 text-muted text-sm">כולל ציוד מקצועי לאיתור</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">פתיחת סתימה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">200₪</td>
              <td class="py-4 px-6 text-muted text-sm">כיור, אסלה, מקלחת</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">סתימה + מצלמת ביוב</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-400₪</td>
              <td class="py-4 px-6 text-muted text-sm">למקרים מורכבים</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">החלפת ברז</td>
              <td class="py-4 px-6 text-brand-600 font-bold">180₪</td>
              <td class="py-4 px-6 text-muted text-sm">לא כולל הברז עצמו</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">התקנת אסלה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-350₪</td>
              <td class="py-4 px-6 text-muted text-sm">כולל חיבור לביוב</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">תיקון דוד שמש</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-250₪</td>
              <td class="py-4 px-6 text-muted text-sm">תלוי בסוג התקלה</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors bg-red-50">
              <td class="py-4 px-6 font-semibold text-dark flex items-center gap-2">
                קריאת חירום (לילה/סופ"ש)
                <span class="bg-red-500 text-white text-xs px-2 py-0.5">24/7</span>
              </td>
              <td class="py-4 px-6 text-red-600 font-bold">+50%</td>
              <td class="py-4 px-6 text-muted text-sm">תוספת על מחיר רגיל</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-center text-muted text-sm mt-6">
        * המחירים הם אומדן ראשוני. המחיר הסופי נקבע לאחר בדיקה במקום ומסוכם מראש לפני תחילת העבודה.
      </p>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">אינסטלטור בכל חיפה והקריות</h2>
        <p class="text-white/70">מגיעים לכל האזורים תוך שעתיים - ובחירום מהר יותר!</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((area) => (
          <a
            href={area.href}
            class="group bg-white/10 hover:bg-accent-500 p-4 text-center transition-all duration-300"
          >
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-accent-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span class="font-semibold text-white">{area.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title="שאלות נפוצות על אינסטלציה"
    subtitle="תשובות לשאלות הנפוצות ביותר"
    faqs={faqs}
  />

  <!-- CTA -->
  <CTASection
    title="יש לכם בעיית אינסטלציה?"
    subtitle="התקשרו עכשיו ונגיע לטפל"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(plumbingSchema)} />
</BaseLayout>
