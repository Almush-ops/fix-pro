---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';

const title = 'הנדימן בחיפה והקריות';
const description = 'שירותי הנדימן מקצועיים בחיפה והקריות. תליית טלוויזיה, הרכבת רהיטים, תיקון דלתות, התקנת מדפים, צביעה ועבודות תחזוקה. הגעה תוך שעתיים.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'הנדימן' },
];

const services = [
  {
    title: 'תליית טלוויזיה',
    description: 'תליית מסכי טלוויזיה על הקיר בכל גודל. כולל הסתרת כבלים, בחירת גובה מיטבי והתקנה מאובטחת.',
    price: 'החל מ-150₪',
  },
  {
    title: 'הרכבת רהיטים',
    description: 'הרכבת רהיטים מאיקאה ומחנויות אחרות - ארונות, מיטות, שולחנות, שידות ועוד. מהיר ומדויק.',
    price: 'החל מ-100₪',
  },
  {
    title: 'תיקון דלתות וחלונות',
    description: 'תיקון דלתות שנתקעות, צירים שחורקים, ידיות שבורות, מנעולים תקולים וחלונות שלא נסגרים כראוי.',
    price: 'החל מ-120₪',
  },
  {
    title: 'התקנת מדפים',
    description: 'התקנת מדפים צפים, מדפי ספרים, מתקנים לאחסון ומדפי מטבח. כולל עיגון מקצועי לכל סוג קיר.',
    price: 'החל מ-80₪',
  },
  {
    title: 'צביעה ושפכטל',
    description: 'צביעת קירות וחדרים, תיקוני שפכטל, מילוי חורים וסדקים. עבודה נקייה עם חומרים איכותיים.',
    price: 'החל מ-100₪ לשעה',
  },
  {
    title: 'עבודות תחזוקה כלליות',
    description: 'תיקונים קטנים, החלפת נורות בגובה, תיקון תריסים, החלפת אביזרים ושאר עבודות בית קטנות.',
    price: 'החל מ-100₪',
  },
];

const faqs = [
  {
    question: 'כמה עולה לתלות טלוויזיה?',
    answer: 'תליית טלוויזיה מתחילה מ-150₪ לעבודה (לא כולל מתקן). המחיר תלוי בגודל המסך, סוג הקיר (גבס/בטון) והאם צריך להסתיר כבלים.',
  },
  {
    question: 'אתם מרכיבים רהיטים מאיקאה?',
    answer: 'כן! אנחנו מרכיבים רהיטים מאיקאה ומכל חנות אחרת. ארון בגדים פשוט לוקח כשעתיים, ארון PAX מורכב יכול לקחת 4-6 שעות.',
  },
  {
    question: 'הדלת שלי נתקעת - מה הפתרון?',
    answer: 'דלת שנתקעת זו בעיה נפוצה. בדרך כלל צריך להתאים את הצירים או לשייף מעט מהדלת. אנחנו מאבחנים את הבעיה ומתקנים במקום.',
  },
  {
    question: 'כמה עולה לצבוע חדר?',
    answer: 'צביעת חדר סטנדרטי (12-15 מ"ר) עולה בין 400-600₪ כולל חומרים. המחיר תלוי במצב הקירות והאם צריך שפכטל מקדים.',
  },
  {
    question: 'מה זה "עבודות תחזוקה כלליות"?',
    answer: 'כל העבודות הקטנות שצריך לעשות בבית: החלפת נורות בגובה, תיקון תריס, החלפת ידית דלת, התקנת וילונות, ועוד המון דברים קטנים שמצטברים.',
  },
];

const handymanSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'שירותי הנדימן',
  description: 'שירותי הנדימן ותחזוקה לבית בחיפה והקריות - תליית טלוויזיה, הרכבת רהיטים, תיקונים',
  provider: {
    '@type': 'LocalBusiness',
    name: 'פיקס פרו',
    telephone: '+972-55-432-9235',
    areaServed: 'חיפה והקריות',
  },
  areaServed: {
    '@type': 'City',
    name: 'חיפה',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'שירותי הנדימן',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.description,
      },
    })),
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- Page Hero -->
  <PageHero
    title="הנדימן בחיפה והקריות"
    subtitle="תליית טלוויזיה, הרכבת רהיטים, תיקונים - כל מה שצריך לבית במקום אחד"
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/services/handyman.webp"
  />

  <!-- Intro Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-muted">
        <p class="text-lg leading-relaxed">
          מחפשים הנדימן מקצועי בחיפה או בקריות? אצלנו תמצאו פתרון אחד לכל העבודות הקטנות בבית -
          תליית טלוויזיה על הקיר, הרכבת רהיטים מאיקאה, תיקון דלתות וחלונות, התקנת מדפים, צביעה קטנה
          וכל מה שצריך לתחזוקת הבית.
        </p>
        <p>
          במקום להתקשר לעשרה בעלי מקצוע שונים לכל דבר קטן, יש לכם עכשיו כתובת אחת.
          אנחנו מגיעים עם כל הכלים הנדרשים, עושים את העבודה מהר ונקי, ונותנים מחיר הוגן ושקוף מראש.
        </p>
        <p>
          אנחנו משרתים את כל אזור חיפה והקריות - קריית ביאליק, קריית מוצקין, קריית ים, קריית אתא,
          נשר, טבעון וזכרון יעקב. רוב העבודות מתבצעות באותו היום או ביום למחרת.
        </p>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">השירותים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">שירותי הנדימן</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <div class="bg-surface p-6 shadow-sm hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-heading font-bold text-dark mb-2">{service.title}</h3>
            <p class="text-muted text-sm mb-4">{service.description}</p>
            <div class="flex items-center justify-between pt-4 border-t border-border">
              <span class="font-bold text-brand-600">{service.price}</span>
              <a href="#contact" class="text-accent-500 font-semibold text-sm hover:text-accent-600 transition-colors">
                הזמינו עכשיו ←
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">למה אנחנו</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            בעל מקצוע רב-תחומי
          </h2>
          <div class="space-y-4 text-muted">
            <p>
              כמה פעמים נמאס לכם לחפש בעל מקצוע לכל דבר קטן?
              תליית תמונה - מישהו אחד. הרכבת ארון - מישהו אחר. תיקון דלת - שלישי.
            </p>
            <p>
              אנחנו מציעים פתרון אחד לכל העבודות הקטנות בבית.
              התקשרו, ספרו מה צריך, ונגיע לעשות את הכל - מהיר, מקצועי ובמחיר הוגן.
            </p>
          </div>
          <ul class="mt-6 space-y-3">
            {['פתרון אחד לכל הבית', 'מחיר שקוף מראש', 'עבודה נקייה ומסודרת', 'זמינות גבוהה'].map((item) => (
              <li class="flex items-center gap-3">
                <div class="w-6 h-6 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-dark">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img
            src="/images/gal/gal-handyman-work.webp"
            alt="גל לוגסי - הנדימן מקצועי בעבודה"
            class="shadow-xl w-full"
            width="900"
            height="1200"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -start-4 w-24 h-24 bg-accent-500 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מחירון</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מחירון שירותי הנדימן</h2>
        <p class="text-muted">מחירים התחלתיים - המחיר הסופי נקבע לפי היקף העבודה</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full bg-surface shadow-sm">
          <thead class="bg-brand-700 text-white">
            <tr>
              <th class="text-start py-4 px-6 font-heading font-bold">שירות</th>
              <th class="text-start py-4 px-6 font-heading font-bold">מחיר</th>
              <th class="text-start py-4 px-6 font-heading font-bold">הערות</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">תליית טלוויזיה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-150₪</td>
              <td class="py-4 px-6 text-muted text-sm">לא כולל מתקן. הסתרת כבלים בתוספת</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">הרכבת ארון איקאה פשוט</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-100₪</td>
              <td class="py-4 px-6 text-muted text-sm">שידה, שולחן, כוננית קטנה</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">הרכבת ארון PAX/בגדים</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-300₪</td>
              <td class="py-4 px-6 text-muted text-sm">תלוי בגודל ומורכבות</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">תיקון דלת</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-120₪</td>
              <td class="py-4 px-6 text-muted text-sm">צירים, ידית, נעילה</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">התקנת מדפים</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-80₪</td>
              <td class="py-4 px-6 text-muted text-sm">למדף. מחיר מיוחד ל-3+</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">צביעת חדר</td>
              <td class="py-4 px-6 text-brand-600 font-bold">400-600₪</td>
              <td class="py-4 px-6 text-muted text-sm">חדר רגיל, כולל חומרים</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">שעת עבודה (כללי)</td>
              <td class="py-4 px-6 text-brand-600 font-bold">100₪</td>
              <td class="py-4 px-6 text-muted text-sm">לעבודות שונות שאין להן מחיר קבוע</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-center text-muted text-sm mt-6">
        * המחירים הם אומדן ראשוני. המחיר הסופי נקבע לאחר הבנת היקף העבודה ומסוכם מראש.
      </p>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">הנדימן בכל חיפה והקריות</h2>
        <p class="text-white/70">מגיעים לכל האזורים לרוב העבודות באותו היום</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((area) => (
          <a
            href={area.href}
            class="group bg-white/10 hover:bg-accent-500 p-4 text-center transition-all duration-300"
          >
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-accent-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span class="font-semibold text-white">{area.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title="שאלות נפוצות על שירותי הנדימן"
    subtitle="תשובות לשאלות הנפוצות ביותר"
    faqs={faqs}
  />

  <!-- CTA -->
  <CTASection
    title="יש לכם משימה לבית?"
    subtitle="התקשרו ונגיע לעשות את זה"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(handymanSchema)} />
</BaseLayout>
