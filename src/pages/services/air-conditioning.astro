---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';

const title = 'טכנאי מזגנים בחיפה והקריות | ניקוי מ-150₪ | פיקס פרו';
const description = 'שירות מיזוג אוויר מקצועי בחיפה והקריות. ניקוי מזגנים, תיקון, התקנה ומילוי גז. ניקוי מיני מרכזי ב-450₪ בלבד. הגעה תוך שעתיים.';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים', href: '/services/' },
  { label: 'מיזוג אוויר' },
];

const services = [
  {
    title: 'ניקוי מזגנים',
    description: 'ניקוי יסודי של מזגנים עיליים ומיני מרכזיים. כולל ניקוי פילטרים, מאייד, מפוח וחיטוי נגד ריחות ועובש.',
    price: 'מ-150₪',
    href: '/air-conditioning/cleaning/',
    highlight: true,
    badge: 'מיני מרכזי 450₪',
  },
  {
    title: 'תיקון מזגנים',
    description: 'אבחון ותיקון כל סוגי התקלות - מזגן לא מקרר, נזילות, רעשים, מילוי גז ועוד. שירות חירום 24/7.',
    price: 'מ-100₪',
    href: '/air-conditioning/repair/',
  },
  {
    title: 'התקנת מזגנים',
    description: 'התקנה מקצועית של מזגנים חדשים - עיליים, מיני מרכזי ומרכזי. כולל צנרת, חיבור וואקום.',
    price: 'מ-400₪',
    href: '/air-conditioning/installation/',
  },
  {
    title: 'טכנאי מזגנים',
    description: 'טכנאי מוסמך עם ניסיון רב. הגעה מהירה תוך שעה לכל אזור חיפה והקריות. כל המותגים.',
    price: 'קריאה 100₪',
    href: '/air-conditioning/technician/',
  },
  {
    title: 'מילוי גז',
    description: 'מילוי גז R410A או R32 למזגנים. כולל בדיקת דליפות. אם צריך למלא תכוף - יש דליפה לתקן.',
    price: 'מ-250₪',
    href: '/air-conditioning/repair/',
  },
  {
    title: 'פירוק והעברת מזגן',
    description: 'פירוק מזגן ממקום קיים והתקנתו מחדש. מתאים למעבר דירה או שיפוץ.',
    price: 'מ-400₪',
    href: '/air-conditioning/installation/',
  },
];

const faqs = [
  {
    question: 'כמה פעמים בשנה צריך לנקות מזגן?',
    answer: 'מומלץ לנקות את המזגן פעמיים בשנה - לפני תחילת עונת הקיץ ולפני עונת החורף. אם המזגן נמצא בשימוש יומיומי או באזור מאובק, כדאי לנקות בתדירות גבוהה יותר.',
  },
  {
    question: 'איך אני יודע שהמזגן צריך מילוי גז?',
    answer: 'סימנים שהמזגן צריך גז: קירור/חימום חלש, יצירת קרח על הצנרת או היחידה הפנימית, רעשים חריגים, או עלייה בחשבון החשמל. אנחנו מבצעים בדיקה ואבחון במקום.',
  },
  {
    question: 'מה ההבדל בין מזגן עילי למיני מרכזי?',
    answer: 'מזגן עילי הוא יחידה בודדת שמותקנת על הקיר ומקררת חדר אחד. מיני מרכזי הוא מערכת עם יחידה מרכזית שמחוברת לכמה יציאות בתקרה ומקררת מספר חדרים.',
  },
  {
    question: 'כמה זמן לוקח לנקות מזגן מיני מרכזי?',
    answer: 'ניקוי מיני מרכזי מקצועי לוקח בין שעה לשעתיים, תלוי במצב המזגן ובמספר היציאות. הניקוי כולל פירוק, ניקוי כל החלקים והרכבה מחדש.',
  },
  {
    question: 'האם אתם מתקינים מזגנים של כל המותגים?',
    answer: 'כן, אנחנו מתקינים ומתקנים מזגנים של כל המותגים המובילים: אלקטרה, תדיראן, גריי, מיצובישי, דייקין, LG, סמסונג ועוד.',
  },
];

const acSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'שירות מיזוג אוויר',
  description: 'שירות מיזוג אוויר מקצועי בחיפה והקריות - ניקוי, תיקון, התקנה ומילוי גז',
  provider: {
    '@type': 'LocalBusiness',
    name: 'פיקס פרו',
    telephone: '+972-55-432-9235',
    areaServed: 'חיפה והקריות',
  },
  areaServed: {
    '@type': 'City',
    name: 'חיפה',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'שירותי מיזוג אוויר',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.description,
      },
    })),
  },
};
---

<BaseLayout title={title} description={description} preloadImage="/images/services/air-conditioning.webp">
  <!-- Page Hero -->
  <PageHero
    title="מיזוג אוויר"
    subtitle="ניקוי, תיקון, התקנה ומילוי גז - שירות מקצועי בחיפה והקריות"
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/services/air-conditioning.webp"
  />

  <!-- Intro Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-muted">
        <p class="text-lg leading-relaxed">
          שירות מיזוג אוויר מקצועי באזור חיפה והקריות הוא הכרחי לתחזוקה נכונה של מערכת המיזוג בבית או בעסק.
          בין אם מדובר בניקוי מזגנים שגרתי, תיקון תקלות, התקנת מזגן חדש או מילוי גז - חשוב לבחור טכנאי מזגנים מנוסה
          שמכיר את כל סוגי המזגנים ויודע לספק שירות מהיר ואיכותי.
        </p>
        <p>
          אנחנו מספקים שירות מיזוג אוויר מקיף לכל אזור חיפה, הקריות והסביבה - קריית ביאליק, קריית מוצקין, קריית ים,
          קריית אתא, נשר, טבעון וזכרון יעקב. הגעה מהירה תוך שעתיים, מחיר שקוף מראש ואחריות מלאה על כל עבודה.
        </p>
        <p>
          המתמחיות שלנו כוללות ניקוי מזגנים עיליים ומיני מרכזיים, תיקון מזגנים מכל הסוגים והמותגים,
          התקנת מזגנים חדשים כולל העברת צנרת, ומילוי גז למזגנים. אנחנו עובדים עם כל המותגים המובילים -
          אלקטרה, תדיראן, גריי, מיצובישי, דייקין, LG וסמסונג.
        </p>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">השירותים שלנו</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark">שירותי מיזוג אוויר</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a href={service.href} class={`group block bg-surface p-6 shadow-sm hover:shadow-lg transition-all duration-300 ${service.highlight ? 'ring-2 ring-accent-500' : ''}`}>
            <div class="flex items-start justify-between mb-2">
              {service.highlight && (
                <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1">
                  המומלץ שלנו
                </span>
              )}
              {service.badge && (
                <span class="inline-block bg-brand-100 text-brand-700 text-xs font-bold px-2 py-1">
                  {service.badge}
                </span>
              )}
            </div>
            <h3 class="text-lg font-heading font-bold text-dark mb-2 group-hover:text-brand-600 transition-colors">{service.title}</h3>
            <p class="text-muted text-sm mb-4">{service.description}</p>
            <div class="flex items-center justify-between pt-4 border-t border-border">
              <span class={`font-bold ${service.highlight ? 'text-accent-500 text-lg' : 'text-brand-600'}`}>
                {service.price}
              </span>
              <span class="text-accent-500 font-semibold text-sm group-hover:text-accent-600 transition-colors">
                לפרטים ←
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">למה אנחנו</p>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-6">
            טכנאי מזגנים מנוסה באזור שלכם
          </h2>
          <div class="space-y-4 text-muted">
            <p>
              עם למעלה מ-15 שנות ניסיון בתחום המיזוג, אנחנו מכירים כל סוג של מזגן ויודעים לטפל בכל בעיה.
              מעילי קטן ועד מיני מרכזי מורכב - אנחנו מספקים שירות מקצועי ואמין.
            </p>
            <p>
              אנחנו עובדים עם כל המותגים המובילים בשוק ומשתמשים בחלפים מקוריים.
              כל עבודה מגיעה עם אחריות מלאה, כי חשוב לנו שתהיו מרוצים.
            </p>
          </div>
          <ul class="mt-6 space-y-3">
            {['מחיר שקוף מראש - בלי הפתעות', 'הגעה תוך שעתיים', 'אחריות על כל עבודה', 'טכנאי מנוסה ומקצועי'].map((item) => (
              <li class="flex items-center gap-3">
                <div class="w-6 h-6 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-dark">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img
            src="/images/gal/gal-tadiran-outdoor.webp"
            alt="גל לוגסי מתקין יחידת מיזוג אוויר חיצונית"
            class="shadow-xl w-full"
            width="800"
            height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -start-4 w-24 h-24 bg-accent-500 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מחירון</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מחירון שירותי מיזוג אוויר</h2>
        <p class="text-muted">מחירים שקופים ללא הפתעות. כל המחירים כוללים מע"מ ואחריות</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full bg-surface shadow-sm">
          <thead class="bg-brand-700 text-white">
            <tr>
              <th class="text-start py-4 px-6 font-heading font-bold">שירות</th>
              <th class="text-start py-4 px-6 font-heading font-bold">מחיר</th>
              <th class="text-start py-4 px-6 font-heading font-bold">הערות</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">ניקוי מזגן עילי</td>
              <td class="py-4 px-6 text-brand-600 font-bold">150₪</td>
              <td class="py-4 px-6 text-muted text-sm">כולל פילטרים וחיטוי</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors bg-accent-50/50">
              <td class="py-4 px-6 font-semibold text-dark flex items-center gap-2">
                ניקוי מיני מרכזי
                <span class="bg-accent-500 text-white text-xs px-2 py-0.5">מבצע</span>
              </td>
              <td class="py-4 px-6 text-accent-500 font-bold text-lg">450₪</td>
              <td class="py-4 px-6 text-muted text-sm">פירוק מלא, ניקוי מאייד וכל החלקים</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">תיקון מזגן</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-200₪</td>
              <td class="py-4 px-6 text-muted text-sm">אבחון במקום, תלוי בסוג התקלה</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">מילוי גז</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-300₪</td>
              <td class="py-4 px-6 text-muted text-sm">R410A או R32, כולל בדיקת נזילות</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">התקנת מזגן עילי</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-500₪</td>
              <td class="py-4 px-6 text-muted text-sm">כולל צנרת עד 3 מטר</td>
            </tr>
            <tr class="hover:bg-accent-50 transition-colors">
              <td class="py-4 px-6 font-semibold text-dark">התקנת מזגן + צנרת ארוכה</td>
              <td class="py-4 px-6 text-brand-600 font-bold">מ-700₪</td>
              <td class="py-4 px-6 text-muted text-sm">צנרת מעל 3 מטר, תלוי באורך</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-center text-muted text-sm mt-6">
        * המחירים הם אומדן ראשוני. המחיר הסופי נקבע לאחר בדיקה במקום ומסוכם מראש.
      </p>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">תהליך העבודה</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">איך זה עובד?</h2>
        <p class="text-muted max-w-2xl mx-auto">תהליך פשוט ומהיר מהשיחה הראשונה ועד לסיום העבודה</p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center relative">
          <div class="w-16 h-16 bg-accent-500 mx-auto flex items-center justify-center mb-4">
            <span class="text-white text-2xl font-heading font-bold">1</span>
          </div>
          <h3 class="font-heading font-bold text-dark mb-2">יצירת קשר</h3>
          <p class="text-muted text-sm">התקשרו או השאירו פרטים ונחזור אליכם תוך דקות</p>
          <div class="hidden md:block absolute top-8 start-[60%] w-full h-0.5 bg-accent-200"></div>
        </div>
        <div class="text-center relative">
          <div class="w-16 h-16 bg-accent-500 mx-auto flex items-center justify-center mb-4">
            <span class="text-white text-2xl font-heading font-bold">2</span>
          </div>
          <h3 class="font-heading font-bold text-dark mb-2">תיאום ביקור</h3>
          <p class="text-muted text-sm">קובעים מועד נוח - הגעה תוך שעתיים לרוב המקרים</p>
          <div class="hidden md:block absolute top-8 start-[60%] w-full h-0.5 bg-accent-200"></div>
        </div>
        <div class="text-center relative">
          <div class="w-16 h-16 bg-accent-500 mx-auto flex items-center justify-center mb-4">
            <span class="text-white text-2xl font-heading font-bold">3</span>
          </div>
          <h3 class="font-heading font-bold text-dark mb-2">בדיקה והצעת מחיר</h3>
          <p class="text-muted text-sm">בודקים את המזגן ומציעים מחיר סופי לפני תחילת העבודה</p>
          <div class="hidden md:block absolute top-8 start-[60%] w-full h-0.5 bg-accent-200"></div>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-500 mx-auto flex items-center justify-center mb-4">
            <span class="text-white text-2xl font-heading font-bold">4</span>
          </div>
          <h3 class="font-heading font-bold text-dark mb-2">ביצוע + אחריות</h3>
          <p class="text-muted text-sm">מבצעים את העבודה ונותנים אחריות מלאה</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands We Service -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">מותגים</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark mb-3">מטפלים בכל המותגים</h2>
        <p class="text-muted max-w-2xl mx-auto">
          אנחנו מכירים לעומק את כל מותגי המזגנים הפופולריים בישראל ויודעים לטפל בכל סוג של תקלה
        </p>
      </div>

      <div class="grid grid-cols-3 md:grid-cols-5 gap-6">
        {['אלקטרה', 'תדיראן', 'גריי', 'מיצובישי', 'דייקין', 'LG', 'סמסונג', 'קריר', 'אמקור', 'טורנדו'].map((brand) => (
          <div class="bg-surface p-4 text-center hover:shadow-md transition-shadow">
            <span class="font-heading font-bold text-dark">{brand}</span>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <p class="text-muted text-sm">
          לא רואים את המותג שלכם? <a href="tel:0554329235" class="text-accent-500 font-semibold hover:underline">התקשרו לבדוק</a> - סביר שאנחנו מטפלים גם בו!
        </p>
      </div>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 md:py-20 bg-brand-700">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-accent-500 font-semibold text-sm uppercase tracking-wide mb-2">אזורי שירות</p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">שירות מיזוג אוויר בכל חיפה והקריות</h2>
        <p class="text-white/70">מגיעים לכל האזורים תוך שעתיים</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { name: 'חיפה', href: '/areas/haifa/' },
          { name: 'קריית ביאליק', href: '/areas/kiryat-bialik/' },
          { name: 'קריית מוצקין', href: '/areas/kiryat-motzkin/' },
          { name: 'קריית ים', href: '/areas/kiryat-yam/' },
          { name: 'קריית אתא', href: '/areas/kiryat-ata/' },
          { name: 'נשר', href: '/areas/nesher/' },
          { name: 'טבעון', href: '/areas/tivon/' },
          { name: 'זכרון יעקב', href: '/areas/zichron-yaakov/' },
        ].map((area) => (
          <a
            href={area.href}
            class="group bg-white/10 hover:bg-accent-500 p-4 text-center transition-all duration-300"
          >
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-accent-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span class="font-semibold text-white">{area.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ
    title="שאלות נפוצות על מיזוג אוויר"
    subtitle="תשובות לשאלות הנפוצות ביותר"
    faqs={faqs}
  />

  <!-- CTA -->
  <CTASection
    title="צריכים שירות מיזוג אוויר?"
    subtitle="התקשרו עכשיו ונגיע תוך שעתיים"
  />

  <!-- Contact Form -->
  <ContactForm variant="card" />

  <!-- Service Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(acSchema)} />
</BaseLayout>
