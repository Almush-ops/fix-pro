---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import CTASection from '../../components/CTASection.astro';
import ContactForm from '../../components/ContactForm.astro';

const title = 'שירותי מזגנים, אינסטלציה והנדימן | פיקס פרו חיפה';
const description = 'שירותי מיזוג אוויר, אינסטלציה והנדימן מקצועיים בחיפה והקריות. ניקוי מזגנים מ-250₪, תיקון נזילות, פתיחת סתימות, הרכבת רהיטים. הגעה תוך שעתיים!';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'שירותים' },
];
---

<BaseLayout title={title} description={description} preloadImage="/images/hero/hero-hvac-pro.webp">
  <!-- Page Hero -->
  <PageHero
    title="השירותים שלנו"
    subtitle="כל מה שצריך לבית ולעסק - במקום אחד, עם שירות מקצועי ואמין"
    breadcrumbs={breadcrumbs}
  />

  <!-- Services Grid -->
  <ServicesGrid title="" subtitle="" />

  <!-- Additional Services -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-dark text-center mb-12">
        מה אנחנו מציעים
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- AC Services -->
        <div class="bg-white p-6 border border-border shadow-sm">
          <h3 class="text-xl font-heading font-bold text-dark mb-4">מיזוג אוויר</h3>
          <ul class="space-y-2 text-muted">
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              ניקוי מזגן עילי
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              ניקוי מיני מרכזי (450₪ בלבד!)
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              תיקון מזגנים
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              התקנת מזגנים
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              מילוי גז
            </li>
          </ul>
        </div>

        <!-- Plumbing Services -->
        <div class="bg-white p-6 border border-border shadow-sm">
          <h3 class="text-xl font-heading font-bold text-dark mb-4">אינסטלציה</h3>
          <ul class="space-y-2 text-muted">
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              תיקון נזילות
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              פתיחת סתימות
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              החלפת ברזים
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              התקנת אסלות וכיורים
            </li>
            <li class="flex items-center gap-2">
              <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              תיקון דודי שמש
            </li>
          </ul>
        </div>

        <!-- Handyman Services -->
        <div class="bg-white p-6 border border-border shadow-sm md:col-span-2">
          <h3 class="text-xl font-heading font-bold text-dark mb-4">הנדימן</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <ul class="space-y-2 text-muted">
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                תליית טלוויזיות
              </li>
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                הרכבת רהיטים
              </li>
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                תיקון דלתות וחלונות
              </li>
            </ul>
            <ul class="space-y-2 text-muted">
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                התקנת מדפים
              </li>
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                צביעה ומריחת שפכטל
              </li>
              <li class="flex items-center gap-2">
                <div class="w-5 h-5 bg-accent-500 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                עבודות תחזוקה כלליות
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection />

  <!-- Contact Form -->
  <ContactForm variant="card" />
</BaseLayout>
